    "collapsible_menu_NTLwXP": {
      "type": "collapsible_menu",
      "blocks": {
        "collapsible_tab_BHRFnT": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "هل الخامة مناسبة للعمل لساعات طويلة؟ وهل توفر راحة وتهوية طوال اليوم؟",
            "content": "<p><strong>نعم، بكل تأكيد.</strong> تم اختيار الأقمشة بعناية فائقة لتناسب الاستخدام اليومي الشاق والعمل لساعات طويلة. الخامات تتميز بمرونة عالية وخفة في الوزن، بالإضافة إلى جزيئات نسيج تسمح بـ <strong>التهوية الكاملة وتمرير الهواء</strong> لمنع التعرق والشعور بالحرارة، مما يضمن لكِ الراحة والانتعاش طوال اليوم.</p>",
            "page": "",
            "icon": "none",
            "icon_advanced_settings": false,
            "icon_height_desktop": 28,
            "icon_height": 27,
            "icon_margin_desktop": 0,
            "icon_margin": 0,
            "open_by_default": false
          }
        },
        "collapsible_tab_mg8QdP": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "هل الأقمشة تحتاج كوي وهل تحافظ على مظهرها المرتب بعد الغسيل والارتداء؟؟",
            "content": "<p><strong>لا تحتاج إلى كوي مستمر.</strong> الأقمشة مصنوعة من خامات مقاومة للتجعد والانكماش بفضل تقنية نسيج متطورة، مما يضمن لكِ الحفاظ على مظهر مرتب، أنيق، وانسيابي حتى بعد ساعات طويلة من الارتداء أو بعد الغسيل المتكرر. كل ما تحتاجينه هو تعليقها مباشرة بعد الغسيل لتبقى جاهزة للارتداء فوراً دون أي عناء.</p>",
            "page": "",
            "icon": "none",
            "icon_advanced_settings": false,
            "icon_height_desktop": 28,
            "icon_height": 27,
            "icon_margin_desktop": 0,
            "icon_margin": 0,
            "open_by_default": false
          }
        },
        "collapsible_tab_miUEad": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "هل المقاسات مطابقة للحجم الحقيقي وكيف يمكنني اختيار المقاس المناسب لي؟",
            "content": "<p><strong>نعم، مقاساتنا مطابقة تماماً للمقاسات العالمية القياسية (True to size).</strong> وننصحكِ دائماً باختيار مقاسكِ المعتاد الذي ترتدينه في أغلب ملابسكِ.وذا كنتِ محتارة بين مقاسين أو ترغبين في دقة متناهية، يمكنكِ الإطلاع على <strong>\"جدول المقاسات\"</strong> المتواجد في صفحة المنتج، والذي يوضح بالـ (سم) مقاسات الصدر، الخصر، والطول لتسهيل الاختيار الأمثل لكِ.</p>",
            "page": "",
            "icon": "none",
            "icon_advanced_settings": false,
            "icon_height_desktop": 28,
            "icon_height": 27,
            "icon_margin_desktop": 0,
            "icon_margin": 0,
            "open_by_default": false
          }
        }
