{{ 'section-shoppable-video.css' | asset_url | stylesheet_tag }}

{% assign background_rgb = section.settings['color-overlay'] | color_to_rgb %}
{% assign text_rgb = section.settings['color-body-text'] | color_to_rgb %}
{% assign heading_rgb = section.settings['color-body-heading'] | color_to_rgb %}

<style>
  section[id="shopify-section-{{ section.id }}"]{
      {% if section.settings.margin-top %}
          --section-gap-top: {{ section.settings.margin-top }}px;
      {% endif %}

      {% if section.settings.margin-bottom %}
          --section-gap-bottom: {{ section.settings.margin-bottom }}px;
      {% endif %}

      {% if section.settings.show_mobile_spacing %}
          --section-gap-top-mobile: {{ section.settings.margin-top-mobile }}px;
      {% endif %}

      {% if section.settings.show_mobile_spacing %}
          --section-gap-bottom-mobile: {{ section.settings.margin-bottom-mobile }}px;
      {% endif %}
      {% if section.settings['color-overlay'] != blank and section.settings['color-overlay'] != 'transparent' and background_rgb != 'rgba(0, 0, 0, 0.0)' %}
        --color-overlay-rgb: {{ section.settings.color-overlay | color_to_rgb | remove: 'rgb(' | remove: ')' }};
          --color-overlay-opacity: {{ section.settings.color-overlay-opacity | divided_by: 100.0 }};
      {% endif %}

      .headline__title{
        {% if section.settings['color-body-heading'] != blank and section.settings['color-body-heading'] != 'transparent' and heading_rgb != 'rgba(0, 0, 0, 0.0)' %}
          --color-custom-text: {{ section.settings.color-body-heading }};
          {% endif %}
      }
  }

  [data-section-id="{{ section.id }}"]
  {

      {% if section.settings.full-width-enabled %}
          --border-radius: 0;
      {% endif %}

      {% if section.settings.original_ratio == 'fixed_height' or section.settings.video_url and section.settings.video_hosted == nil %}
          --section-height: {{ section.settings.mobile_fixed_height }}px;
          --section-height-desk: {{ section.settings.desktop_fixed_height }}px;
      {% endif %}

      .hero__img--placeholder{
          object-position: {{ section.settings.cover_image.presentation.focal_point }};
      }

      {% if section.settings.container_max_width != 0 %}
          --text-container-width: {{ section.settings.container_max_width }}px;
      {% endif %}
  }

  [data-section-id="{{ section.id }}"] .hero--video-background {
    {% if section.settings['color-body-text'] != blank and section.settings['color-body-text'] != 'transparent' and text_rgb != 'rgba(0, 0, 0, 0.0)' %}
      --color-custom-text: {{ section.settings.color-body-text }};
    {% endif %}
  }

  {%- for block in section.blocks -%}
  [data-block-id="{{ block.id }}"]
  {

      --font-headline-scale-desk: {{ block.settings.size_heading | divided_by: 100.0 }};
      --font-headline-scale: {{ block.settings.size_heading_mobile | divided_by: 100.0 }};

    {% if block.type == 'countdown_timer' %}
      --font-timer-scale-desk: {{ block.settings.scale_timer | divided_by: 100.0 }};
      --font-timer-scale: {{ block.settings.scale_timer_mobile | divided_by: 100.0 }};
      --font-timer: {% if block.settings.timer_style == 'headline' %}var(--font-headline){% endif %}
    {% endif %}

    {% if block.type == 'icon_with_text' %}
      --icon-height-desktop: {{ block.settings.icon_height_desktop }}px;
      --icon-height: {{ block.settings.icon_height }}px;
      --icon-margin-desktop: {{ block.settings.icon_margin_desktop }}px;
      --icon-margin: {{ block.settings.icon_margin }}px;
      --size-heading-desktop: {{ block.settings.size_heading | divided_by: 100.0 }};
      --size-heading: {{ block.settings.size_heading_mobile | divided_by: 100.0 }};
      --gap: {{ block.settings.gap }}px;
      --margin-top: {{ block.settings.margin_top }}px;
      --margin-bottom: {{ block.settings.margin_bottom }}px;
      --margin-left: {{ block.settings.margin_left }}px;
      --margin-left-desktop: {{ block.settings.margin_left_desktop }}px;
      {% if block.settings.icon_alignment != 'inherit' %}
      --icon-alignment: {{ block.settings.icon_alignment }};
      {% endif %}
      {% if block.settings.icon_alignment_mobile != 'inherit' %}
      --icon-alignment-mobile: {{ block.settings.icon_alignment_mobile }};
      {% endif %}

      {% if block.settings.icon_alignment == "flex-start" %}
        --icon-text-alignment: left;
      {% elsif block.settings.icon_alignment == "flex-end" %}
        --icon-text-alignment: right;
      {% elsif block.settings.icon_alignment == "center" %}
        --icon-text-alignment: center;
      {% endif %}

      {% if block.settings.icon_alignment_mobile == "flex-start" %}
        --icon-text-alignment-mobile: left;
      {% elsif block.settings.icon_alignment_mobile == "flex-end" %}
        --icon-text-alignment-mobile: right;
      {% elsif block.settings.icon_alignment_mobile == "center" %}
        --icon-text-alignment-mobile: center;
      {% endif %}
    {% endif %}

    {% if block.type == 'text' and block.settings.text_style == 'subtitle' %}
        --font-base: var(--font-headline);
    {% endif %}

    {% if block.type == 'subheading' and block.settings.subheading_advanced_settings %}
      --font-subheading-scale: {{ block.settings.size_text_mobile | divided_by: 100.0 }};
      --font-subheading-scale-desk: {{ block.settings.size_text_desktop | divided_by: 100.0 }};
      --subheading-letter-spacing: {{ block.settings.letter_spacing }}px;
      {% if block.settings.text_uppercase %}
        --subheading-text-transform: uppercase;
      {% endif %}
      {% if block.settings.text_style == 'body' %}
        --subheading-font-family: var(--font-base);
      {% endif %}
    {% endif %}

  }
  {%- endfor -%}
</style>

{% if section.settings['full-width-enabled'] %}
  {% assign width_line = 'hero__wrapper--full' %}
{% else %}
  {% assign width_line = 'hero__wrapper' %}
{% endif %}

{% assign button_label = blank %}
{% assign button_link = null %}

{% for block in section.blocks %}
  {% if block.type == 'button' %}
    {% assign button_label = block.settings.button_label | default: '' %}
    {% assign button_link = block.settings.button_link %}
  {% endif %}
{% endfor %}

<script src="{{ 'low-power-video.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'video-controls.js' | asset_url }}" defer="defer"></script>

<low-power-video>
  <div class="{{ width_line }} section-background-video" data-section-id="{{ section.id }}">
    <div>
      {% if section.settings.advanced_heading %}
        {% if section.settings.heading_richtext != blank %}
            <div class="headline headline--rich {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
                {{ section.settings.heading_richtext }}
            </div>
        {% endif %}
      {% else %}
        {% if section.settings.heading != blank %}
            {% render 'headline', title: section.settings.heading %}
        {% endif %}
      {% endif %}
      <div
        class="background-video {% if section.settings.original_ratio == 'original_ratio' %} background-video--og-ratio {% endif %}  {% if settings.animations %}scroll-trigger animate--slide-in {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}{% endif %}"
      >
        {% render 'hero',
          type: 'blocks',
          desktop_text_horizontal_position: section.settings.desktop_text_horizontal_position,
          desktop_text_vertical_position: section.settings.desktop_text_vertical_position,
          mobile_text_horizontal_position: section.settings.mobile_text_horizontal_position,
          mobile_text_vertical_position: section.settings.mobile_text_vertical_position,
          desktop_image: section.settings.cover_image,
          mobile_video: section.settings.mobile_video_hosted,
          video: section.settings.video_hosted,
          video_url: section.settings.video_url,
          placeholder: 'hero-apparel-1',
          blocks: section.blocks,
          link_only_on_button: false,
          video_controls: section.settings.video_controls,
          video_custom_play_controls: section.settings.video_custom_play_controls,
          video_custom_mute_controls: section.settings.video_custom_mute_controls,
          autoplay: section.settings.autoplay,
          lcp_video: true
        %}
      </div>
    </div>
  </div>
</low-power-video>

{{ 'section-video.css' | asset_url | stylesheet_tag }}

