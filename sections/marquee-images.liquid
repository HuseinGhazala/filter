{{ 'section-brands.css' | asset_url | stylesheet_tag }}
{{ 'swiper.css' | asset_url | stylesheet_tag }}

{% assign background_rgb = section.settings.background_color | color_to_rgb %}
{% assign text_rgb = section.settings['color-body-text'] | color_to_rgb %}

<style>
  [data-section-id="{{ section.id }}"]
  {
  {% if section.settings.margin-top %}
    --section-gap-top: {{ section.settings.margin-top }}px;
  {% endif %}

  {% if section.settings.margin-bottom %}
    --section-gap-bottom: {{ section.settings.margin-bottom }}px;
  {% endif %}

      {%- if section.settings.show_mobile_spacing -%}
          --section-gap-top-mobile: {{ section.settings.margin-top-mobile }}px;
      {%- endif -%}

      {%- if section.settings.show_mobile_spacing -%}
          --section-gap-bottom-mobile: {{ section.settings.margin-bottom-mobile }}px;
      {%- endif -%}

  {% if section.settings.background_color != blank and section.settings.background_color != 'transparent' and background_rgb != 'rgba(0, 0, 0, 0.0)' %}
    --color-background: {{ section.settings.background_color }};
  {% endif %}

  {% if section.settings['color-body-text'] != blank and section.settings['color-body-text'] != 'transparent' and text_rgb != 'rgba(0, 0, 0, 0.0)' %}
    --color-custom-text: {{ section.settings.color-body-text }};
  {% endif %}

    --section-height: {{ section.settings.mobile_fixed_height }}px;
    --section-height-desk: {{ section.settings.desktop_fixed_height }}px;
    --marquee-gap: {{ section.settings.gap }}px;
    --marquee-gap-desk: {{ section.settings.gap_desk }}px;
  }

  /* تنسيق شاشات الفيديو لضمان التفافها وعرضها بشكل متناسق مع الماركي */
  .wt-brands__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>

{% case section.settings.animation_speed %}
  {% when '150' %}
    {% assign speed = 30 | times: section.blocks.size | round %}
  {% when '100' %}
    {% assign speed = 16.6 | times: section.blocks.size | round %}
  {% when '50' %}
    {% assign speed = 8.3 | times: section.blocks.size | round %}
{% endcase %}

<div
  data-section-id="{{ section.id }}"
  class="wt-slider wt-brands__container wt-brands__container--marquee wt-marquee-images__container"
>
  {% if section.settings.advanced_heading %}
    {% if section.settings.heading_richtext != blank %}
        <div class="headline headline--rich {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
            {{ section.settings.heading_richtext }}
        </div>
    {% endif %}
  {% else %}
    {% if section.settings.heading != blank %}
        {% render 'headline', title: section.settings.heading %}
    {% endif %}
  {% endif %}

  <div
    class="wt-slider__container--featured wt-brands__marquee 
    {% if section.settings.animation_direction == 'right' %}wt-brands__marquee--right{% endif %}"
      style="--time:{{ speed }}s"
  >
    {% liquid
      if section.blocks.size > 3
          assign justify_class = 'wt-brands--many-items'
      else
          assign justify_class = 'wt-brands--few-items'
      endif
        assign multiply = 3
    %}

    <div
      class="wt-brands {{ justify_class }}  wt-brands__marquee__content wt-brands__marquee__content--1"
    >
      {% for i in (1..multiply) %}
        {% for block in section.blocks %}
          <div class="wt-brands__item">
              {% if block.settings.link != blank %}
                <a
                  href="{{ block.settings.link }}"
                  class="wt-brands__link"
                  aria-label="{{ 'aria-label.brands-url' | t }}"
                  tabindex="-1"
                >
              {% else %}
                <div class="wt-brands__link">
              {% endif %}

                {% if block.settings.video != blank %}
                  {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'wt-brands__image wt-brands__video' }}
                {% elsif block.settings.desktop_image != blank %}
                  {% assign alt_text = block.settings.desktop_image.alt | escape | default: "" %}
                  {% assign desktop_width = block.settings.desktop_image.width | times: 2 %}
                  {{
                    block.settings.desktop_image
                    | image_url: width: desktop_width
                    | image_tag:
                      alt: alt_text,
                      loading: 'eager',
                      class: 'wt-brands__image'
                  }}
                {% else %}
                  <div class="wt-brands__image">
                    {{ 'collection-apparel-1' | placeholder_svg_tag: 'wt-brands__image--placeholder' }}
                  </div>
                {% endif %}

              {% if block.settings.link != blank %}
                </a>
              {% else %}
                </div>
              {% endif %}
          </div>
        {% endfor %}
      {% endfor %}
    </div>

    <div class="wt-brands {{ justify_class }} wt-brands__marquee__content wt-brands__marquee__content--2">
      {% for i in (1..multiply) %}
        {% for block in section.blocks %}
          <div class="wt-brands__item">
              {% if block.settings.link != blank %}
                <a
                  href="{{ block.settings.link }}"
                  class="wt-brands__link"
                  aria-label="{{ 'aria-label.brands-url' | t }}"
                  tabindex="-1"
                >
              {% else %}
                <div class="wt-brands__link">
              {% endif %}

                {% if block.settings.video != blank %}
                  {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'wt-brands__image wt-brands__video' }}
                {% elsif block.settings.desktop_image != blank %}
                  {% assign alt_text = block.settings.desktop_image.alt | escape | default: "" %}
                  {% assign desktop_width = block.settings.desktop_image.width | times: 2 %}
                  {{
                    block.settings.desktop_image
                    | image_url: width: desktop_width
                    | image_tag:
                      alt: alt_text,
                      loading: 'eager',
                      class: 'wt-brands__image'
                  }}
                  <span class="hidden">{{ alt_text }}</span>
                {% else %}
                  <div class="wt-brands__image">
                    {{ 'collection-apparel-1' | placeholder_svg_tag: 'wt-brands__image--placeholder' }}
                  </div>
                {% endif %}

              {% if block.settings.link != blank %}
                </a>
              {% else %}
                </div>
              {% endif %}
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.marquee_images.name",
  "tag": "section",
  "class": "wt-marquee-images",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.marquee_images.settings.important-information.content",
      "info": "t:sections.marquee_images.settings.important-information.info"
    },
    {
      "type": "checkbox",
      "id": "advanced_heading",
      "label": "t:sections.global.advanced_heading.label",
      "info": "t:sections.global.advanced_heading.info"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "t:sections.settings.settings.heading.label",
      "default": "Marquee images",
      "visible_if": "{{ section.settings.advanced_heading == false }}"
    },
    {
      "type": "richtext",
      "id": "heading_richtext",
      "label": "t:sections.logo-banner.settings.content.headline.label",
      "default": "<h2>Marquee images</h2>",
      "visible_if": "{{ section.settings.advanced_heading == true }}"
    },
    {
      "type": "select",
      "id": "animation_direction",
      "options": [
        {
          "value": "left",
          "label": "t:sections.marquee_images.settings.animation_direction.options.left.label"
        },
        {
          "value": "right",
          "label": "t:sections.marquee_images.settings.animation_direction.options.right.label"
        }
      ],
      "label": "t:sections.marquee_images.settings.animation_direction.label",
      "default": "left"
    },
    {
      "type": "select",
      "id": "animation_speed",
      "options": [
        {
          "value": "150",
          "label": "t:sections.brands.settings.marquee-speed.slow.label"
        },
        {
          "value": "100",
          "label": "t:sections.brands.settings.marquee-speed.normal.label"
        },
        {
          "value": "50",
          "label": "t:sections.brands.settings.marquee-speed.fast.label"
        }
      ],
      "label": "t:sections.brands.settings.marquee-speed.label",
      "default": "100"
    },
    {
      "type": "header",
      "content": "t:sections.global.desktop_version"
    },
    {
      "type": "range",
      "id": "desktop_fixed_height",
      "min": 60,
      "max": 1000,
      "unit": "px",
      "step": 20,
      "default": 320,
      "label": "t:sections.marquee_images.settings.fixed_height.label"
    },
    {
      "type": "range",
      "id": "gap_desk",
      "min": 4,
      "max": 40,
      "step": 4,
      "default": 24,
      "unit": "px",
      "label": "t:sections.lookbook.settings.gap.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.mobile_version"
    },
    {
      "type": "range",
      "id": "mobile_fixed_height",
      "min": 40,
      "max": 1000,
      "unit": "px",
      "step": 20,
      "default": 220,
      "label": "t:sections.marquee_images.settings.fixed_height.label"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 4,
      "max": 40,
      "step": 4,
      "default": 24,
      "unit": "px",
      "label": "t:sections.lookbook.settings.gap.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.colors",
      "info": "t:sections.global.colors-info"
    },
    {
      "type": "color",
      "id": "color-body-text",
      "label": "t:sections.settings.settings.text-color.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.settings.settings.background-color.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.section_spacing"
    },
    {
      "type": "range",
      "id": "margin-top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-top.label"
    },
    {
      "type": "range",
      "id": "margin-bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-bottom.label",
      "info": "t:sections.settings.settings.distance-bottom.info"
    },
    {
      "type": "checkbox",
      "id": "show_mobile_spacing",
      "label": "t:sections.settings.settings.show-mobile-spacing.label"
    },
    {
      "type": "range",
      "id": "margin-top-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-top-mobile.label",
      "visible_if": "{{ section.settings.show_mobile_spacing }}"
    },
    {
      "type": "range",
      "id": "margin-bottom-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-bottom-mobile.label",
      "visible_if": "{{ section.settings.show_mobile_spacing }}"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.brands.settings.image.name",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "t:sections.settings.settings.image.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.settings.settings.link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.marquee_images.name",
      "category": "t:sections.categories.storytelling",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}