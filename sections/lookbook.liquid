{% assign background_rgb = section.settings['color-overlay'] | color_to_rgb %}
{% assign text_rgb = section.settings['color-body-text'] | color_to_rgb %}

<style>
  #shopify-section-{{ section.id }}{
      {% if section.settings['color-overlay'] != blank and section.settings['color-overlay'] != 'transparent' and background_rgb != 'rgba(0, 0, 0, 0.0)' %}
        --color-overlay-rgb: {{ section.settings.color-overlay | color_to_rgb | remove: 'rgb(' | remove: ')' }};
        --color-overlay-opacity: {{ section.settings.color-overlay-opacity | divided_by: 100.0 }};
      {% endif %}
  }

  [data-section-id="{{ section.id }}"]
  {

      {% if section.settings.margin-top %}
          --section-gap-top: {{ section.settings.margin-top }}px;
      {% endif %}

      {% if section.settings.margin-bottom %}
          --section-gap-bottom: {{ section.settings.margin-bottom }}px;
      {% endif %}

      {%- if section.settings.show_mobile_spacing -%}
          --section-gap-top-mobile: {{ section.settings.margin-top-mobile }}px;
      {%- endif -%}

      {%- if section.settings.show_mobile_spacing -%}
          --section-gap-bottom-mobile: {{ section.settings.margin-bottom-mobile }}px;
      {%- endif -%}

      --lookbook-gap: {{ section.settings.column_gap }}px;
      --lookbook-gap-desk: {{ section.settings.column_gap_desk }}px;

      {% if section.settings['color-body-text'] != blank and section.settings['color-body-text'] != 'transparent' and text_rgb != 'rgba(0, 0, 0, 0.0)' %}
        --color-custom-text: {{ section.settings.color-body-text }};
      {% endif %}

      {% if section.settings.full-width-enabled %}
          --border-radius: 0;
      {% endif %}

      {% for block in section.blocks %}
          .wt-lookbook__image{
              object-position: {{ block.settings.desktop_image.presentation.focal_point }};
          }

      {% endfor %}

  }

   .wt-lookbook__section .headline__title, 
    .wt-lookbook__container .headline {
      text-align: {{ section.settings.heading_alignment }};
      font-weight: 500;
      font-size: 32px;
  color: var(--color-custom-text, var(--color-headings-text, var(--color-text)));
    }
    .wt-lookbook__section .heading-image{
      text-align: {{ section.settings.heading_alignment }};
      font-weight: 400;
      font-size: 24px;
        color: var(--color-custom-text, var(--color-headings-text, var(--color-text)));

    }
    @media screen and (max-width: 749px) {
      .wt-lookbook__section .headline__title, 
      .wt-lookbook__container .headline {
        font-size: 18px;
      }
      .wt-lookbook__section .heading-image{
        font-size: 16px;
      }
    }
      

</style>

{% if section.settings['full-width-enabled'] %}
  {% assign width_line = 'hero__wrapper--full' %}
{% else %}
  {% assign width_line = 'hero__wrapper' %}
{% endif %}

<div class="{{ width_line }}" data-section-id="{{ section.id }}">
  <div class="wt-lookbook__container">

    {% if section.settings.advanced_heading %}
      {% if section.settings.heading_richtext != blank %}
          <div class="headline headline--rich {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %} {% if section.settings.heading_disable_on_mobile == true %} hero__title--mobile{% endif %}">
              {{ section.settings.heading_richtext }}
          </div>
      {% endif %}
    {% else %}
      {% if section.settings.heading != blank %}
          {% if section.settings.heading_disable_on_mobile %}{% assign heading_mobile_class = 'hero__title--mobile' %}{% else %}{% assign heading_mobile_class = '' %}{% endif %}
          {% render 'headline', title: section.settings.heading, custom_class: heading_mobile_class %}
      {% endif %}
    {% endif %}

    <ul class="wt-lookbook__list {% if section.settings.full-width-enabled %}wt-lookbook__full{% endif %}">
      {% for block in section.blocks %}
        <li
          {% if settings.animations %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
          class="wt-lookbook__item {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
        >
        {% if block.settings.link %}
          <a href="{{ block.settings.link }}" class="wt-lookbook__item__link">
        {% endif %}
          
          <div class="wt-icon wt-lookbook__link">
            
            {% case block.type %}
            {% when 'image' %}
              {% assign alt_text = block.settings.desktop_image.alt | escape | default: ""%}
              {% if block.settings.desktop_image != blank %}
                {{
                  block.settings.desktop_image
                  | image_url: width: 1000
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 750px) 750px, 100vw',
                    widths: '750, 1500, 2250, 3000',
                    alt: alt_text,
                    class: 'wt-lookbook__image'
                }}

                 {% if block.settings.heading_image != blank %}
              <div class=" heading-image {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %} ">
                  {{  block.settings.heading_image }}
              </div>
            {% endif %}

              {% else %}
                {{ 'collection-apparel-1' | placeholder_svg_tag: 'wt-lookbook__item--placeholder' }}
              {% endif %}
            {% when 'video' %}
              {% if block.settings.video_hosted != blank %}
                {{
                  block.settings.video_hosted
                  | video_tag:
                    autoplay: true,
                    loop: true,
                    muted: true,
                    image_size: '600x',
                    class: 'wt-lookbook__image'
                }}
                {% else %}
                {{ 'collection-apparel-1' | placeholder_svg_tag: 'wt-lookbook__item--placeholder' }}
              {% endif %}
              {% endcase %}
          </div>
        {% if block.settings.link %}
          </a>
        {% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.lookbook.name",
  "tag": "section",
  "class": "wt-lookbook__section",
  "max_blocks": 20,
  "settings": [
    {
      "type": "checkbox",
      "id": "advanced_heading",
      "label": "t:sections.global.advanced_heading.label",
      "info": "t:sections.global.advanced_heading.info"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "t:sections.settings.settings.heading.label",
      "default": "Lookbook",
      "visible_if": "{{ section.settings.advanced_heading == false }}"
    },
    {
      "type": "richtext",
      "id": "heading_richtext",
      "label": "t:sections.logo-banner.settings.content.headline.label",
      "default": "<h2>Lookbook</h2>",
      "visible_if": "{{ section.settings.advanced_heading == true }}"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "show_icons",
      "label": "t:sections.lookbook.settings.show_icons.label",
      "default": true,
      "info": "t:sections.lookbook.settings.show_icons.info"
    },
    {
      "type": "checkbox",
      "id": "heading_disable_on_mobile",
      "label": "t:sections.global.heading_disable_on_mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "full-width-enabled",
      "label": "t:sections.settings.settings.section-full-width.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.global.desktop_version"
    },
    {
      "type": "range",
      "id": "column_gap_desk",
      "min": 8,
      "max": 32,
      "step": 8,
      "default": 16,
      "unit": "px",
      "label": "t:sections.lookbook.settings.gap.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.mobile_version"
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 8,
      "max": 32,
      "step": 8,
      "default": 8,
      "unit": "px",
      "label": "t:sections.lookbook.settings.gap.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.colors"
    },
    {
      "type": "color",
      "id": "color-body-text",
      "label": "t:sections.settings.settings.text-color.label"
    },
    {
      "type": "color",
      "id": "color-overlay",
      "label": "t:sections.settings.settings.background-color.label"
    },
    {
      "type": "range",
      "id": "color-overlay-opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "label": "t:sections.settings.settings.background-opacity.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.section_spacing"
    },
    {
      "type": "range",
      "id": "margin-top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-top.label"
    },
    {
      "type": "range",
      "id": "margin-bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-bottom.label",
      "info": "t:sections.settings.settings.distance-bottom.info"
    },
    {
      "type": "checkbox",
      "id": "show_mobile_spacing",
      "label": "t:sections.settings.settings.show-mobile-spacing.label"
    },
    {
      "type": "range",
      "id": "margin-top-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-top-mobile.label",
      "visible_if": "{{ section.settings.show_mobile_spacing }}"
    },
    {
      "type": "range",
      "id": "margin-bottom-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-bottom-mobile.label",
      "visible_if": "{{ section.settings.show_mobile_spacing }}"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.brands.settings.image.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "t:sections.settings.settings.image.label"
        },
        {
          "type": "textarea",
          "id": "heading_image",
          "label": "t:sections.settings.settings.heading.label",
          "default": "Lookbook",
          "visible_if": "{{ section.settings.advanced_heading == false }}"
        },
        {
          "type": "select",
          "id": "button_select",
          "options": [
            {
              "value": "primary",
              "label": "t:sections.settings.settings.button_select.primary.label"
            },
            {
              "value": "secondary",
              "label": "t:sections.settings.settings.button_select.secondary.label"
            }
          ],
          "default": "primary",
          "label": "t:sections.settings.settings.button_select.default.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.settings.settings.link.label"
        }
      ]
    },
    {
      "type": "video",
      "name": "t:sections.background-video.settings.video.content",
      "settings": [
        {
          "type": "video",
          "id": "video_hosted",
          "label": "t:sections.logo-banner.settings.video-hosted.label"
        },
        {
          "type": "select",
          "id": "button_select",
          "options": [
            {
              "value": "primary",
              "label": "t:sections.settings.settings.button_select.primary.label"
            },
            {
              "value": "secondary",
              "label": "t:sections.settings.settings.button_select.secondary.label"
            }
          ],
          "default": "primary",
          "label": "t:sections.settings.settings.button_select.default.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.settings.settings.link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.lookbook.presets.name",
      "category": "t:sections.categories.storytelling",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
         {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
