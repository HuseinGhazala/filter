{{ 'swiper.css' | asset_url | stylesheet_tag }}

{% assign heading_rgb = section.settings.heading_color | color_to_rgb %}
{% assign background_rgb = section.settings.background_color | color_to_rgb %}
{% assign text_rgb = section.settings.text_color | color_to_rgb %}

<style>
  [data-section-id="{{ section.id }}"] {

    {% if section.settings.margin-top %}
        --section-gap-top: {{ section.settings.margin-top }}px;
    {% endif %}

    {% if section.settings.margin-bottom %}
        --section-gap-bottom: {{ section.settings.margin-bottom }}px;
    {% endif %}

      {%- if section.settings.show_mobile_spacing -%}
          --section-gap-top-mobile: {{ section.settings.margin-top-mobile }}px;
      {%- endif -%}

      {%- if section.settings.show_mobile_spacing -%}
          --section-gap-bottom-mobile: {{ section.settings.margin-bottom-mobile }}px;
      {%- endif -%}

    {% if section.settings.full-width-enabled %}
        --border-radius: 0;
    {% endif %}

    {% if section.settings.slide_height == 'fixed_height' %}
      --section-height: {{ section.settings.mobile_fixed_height }}px;
      --section-height-desk: {{ section.settings.desktop_fixed_height }}px;
    {% endif %}

    {% if section.settings.slide_height == 'adapt_to_first_image' %}
      --first-slide-ratio: {{ section.blocks.first.settings.mobile_image.aspect_ratio | default: 1 }};
      --first-slide-ratio-desk: {{ section.blocks.first.settings.desktop_image.aspect_ratio | default: 2.5 }};
    {% endif %}

    {% if section.settings['background_color'] != blank and section.settings['background_color'] != 'transparent' and background_rgb != 'rgba(0, 0, 0, 0.0)' %}
      --color-background: {{ section.settings.background_color }};
    {% endif %}



    .headline__title{
      {% if section.settings.heading_color != blank and section.settings.heading_color != 'transparent' and heading_rgb != 'rgba(0, 0, 0, 0.0)' %}
        --color-custom-text: {{ section.settings.heading_color }};
        {% endif %}
    }
  }

  [data-section-id="{{ section.id }}"] slideshow-section {
    {% if section.settings['text_color'] != blank and section.settings['text_color'] != 'transparent' and text_rgb != 'rgba(0, 0, 0, 0.0)' %}
      --color-custom-text: {{ section.settings.text_color }};
    {% endif %}
    {% if section.settings.cursor_navigation %}
      --slideshow-cursor-size: {{ section.settings.cursor_size }}px;
    {% endif %}
  }

  {%- for block in section.blocks -%}
    {% assign background_rgb = block.settings.color-overlay | color_to_rgb %}
    {% assign text_rgb = block.settings.color-body-text | color_to_rgb %}

    {% assign out_background_rgb = block.settings.out-background-color | color_to_rgb %}
    {% assign out_text_rgb = block.settings.out-text-color | color_to_rgb %}

      [data-block-id="{{ block.id }}"] {

        {% if block.settings['color-overlay'] != blank and block.settings['color-overlay'] != 'transparent' and background_rgb != 'rgba(0, 0, 0, 0.0)' %}
          --color-overlay-rgb: {{ block.settings.color-overlay | color_to_rgb | remove: 'rgb(' | remove: ')' }};
          --color-overlay-opacity: {{ block.settings.color-overlay-opacity | divided_by: 100.0 }};
        {% endif %}

        {% if block.settings['color-body-text'] != blank and block.settings['color-body-text'] != 'transparent' and text_rgb != 'rgba(0, 0, 0, 0.0)' %}
          --color-custom-text: {{ block.settings.color-body-text }};
        {% endif %}

        {% if section.settings.out_hero_mobile %}
          {% if block.settings.out-background-color != blank and block.settings.out-background-color != 'transparent' and out_background_rgb != 'rgba(0, 0, 0, 0.0)' %}
            --slide-out-background-color: {{ block.settings.out-background-color }};
          {% endif %}

          {% if block.settings.out-text-color != blank and block.settings.out-text-color != 'transparent' and out_text_rgb != 'rgba(0, 0, 0, 0.0)' %}
            --slide-out-text-color: {{ block.settings.out-text-color }};
          {% endif %}
        {% endif %}

        {% if block.settings.text_style == 'subtitle' %}
          --font-base: var(--font-headline);
        {% endif %}

        {% if block.settings.container_max_width != 0 %}
          --text-container-width: {{ block.settings.container_max_width }}px;
        {% endif %}

      }
  {%- endfor -%}

    {%- for block in section.blocks -%}
      {% assign background_rgb = block.settings.out-background-color | color_to_rgb %}
      {% assign text_rgb = block.settings.out-text-color | color_to_rgb %}
        [data-block-id="{{ block.id }}"]
        {

            --font-headline-scale-desk: {{ block.settings.size_heading | divided_by: 100.0 }};

            --font-headline-scale: {{ block.settings.size_heading_mobile | divided_by: 100.0 }};

            {% if block.type == 'slide' and block.settings.subheading_advanced_settings %}
              --font-subheading-scale: {{ block.settings.size_text_mobile | divided_by: 100.0 }};
              --font-subheading-scale-desk: {{ block.settings.size_text_desktop | divided_by: 100.0 }};
              --subheading-letter-spacing: {{ block.settings.letter_spacing }}px;
              {% if block.settings.text_uppercase %}
                --subheading-text-transform: uppercase;
              {% endif %}
              {% if block.settings.subheading_text_style == 'body' %}
                --subheading-font-family: var(--font-base);
              {% endif %}
            {% endif %}

            {% if section.settings.out_hero_mobile %}
              {% if block.settings['out-background-color'] != blank and block.settings['out-background-color'] != 'transparent' and background_rgb != 'rgba(0, 0, 0, 0.0)' %}
                --slide-out-background-color: {{ block.settings.out-background-color }};
                {% endif %}
                {% if block.settings['out-text-color'] != blank and block.settings['out-text-color'] != 'transparent' and text_rgb != 'rgba(0, 0, 0, 0.0)' %}
                  --slide-out-text-color: {{ block.settings.out-text-color }};
                {% endif %}
            {% endif %}
        }
    {%- endfor -%}
</style>

{% if section.settings['full-width-enabled'] %}
  {% assign width_line = 'hero__wrapper--full' %}
{% else %}
  {% assign width_line = 'hero__wrapper' %}
{% endif %}

<div data-section-id="{{ section.id }}" class="wt-slider--wrapper">

  {% if section.settings.advanced_heading %}
    {% if section.settings.heading_richtext != blank %}
        <div class="headline headline--rich {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
            {{ section.settings.heading_richtext }}
        </div>
    {% endif %}
  {% else %}
    {% if section.settings.heading != blank %}
        {% render 'headline', title: section.settings.heading %}
    {% endif %}
  {% endif %}

  <!-- Slider main container -->
  <slideshow-section
    class="{{ width_line }} wt-slider wt-slider--hero {% if settings.animations and section.settings['full-width-enabled'] != true %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
    {% if section.settings.cursor_navigation %}data-cursor-nav="true"{% endif %}
  >
    {% if request.design_mode %}
      <script data-swiper-configuration type="text/json">
        {
          "autoHeight": false,
          "slidesPerView": 1,
          "enableOnMedia": "(min-width: 0px)"
        }
      </script>
    {% else %}
      <script data-swiper-configuration type="text/json">
        {
          "enableOnMedia": "(min-width: 0px)",
          "autoHeight": false,
          "slidesPerView": 1,
          {%- if section.blocks.size > 1 -%}
            "loop": true,
          {%- endif -%}
          "lazy": true
          {%- if section.settings.auto-rotate -%}
          ,"autoplay": {
            "delay": 5000,
            "pauseOnMouseEnter": true,
            "disableOnInteraction": false
          }
          {%- endif -%}
        }
      </script>
    {% endif %}

    <div
      data-swiper
      class="wt-slider__container wt-slider__container--hero loading {% if section.settings.full-width-enabled == true %}wt-slider__container--full {% endif %}"
    >
      <!-- Additional required wrapper -->
      <div data-swiper-container class="loading">
        <!-- Slides -->
        {%- for block in section.blocks -%}
          {% if section.settings.out_hero_mobile %}
            {% assign customclass = 'hero--out-mobile' %}
            {% assign out_bg_rgb = block.settings.out-background-color | color_to_rgb %}
            {% if block.settings.out-background-color != blank and block.settings.out-background-color != 'transparent' and out_bg_rgb != 'rgba(0, 0, 0, 0.0)' %}
              {% assign customclass = customclass | append: ' hero--out-has-bg' %}
            {% endif %}
          {% else %}
            {% assign customclass = '' %}
          {% endif %}

          <div
            class="swiper-lazy wt-slideshow__swiper-lazy"
            data-swiper-slide
            data-block-id="{{ block.id }}"
            {{ block.shopify_attributes }}
          >
            {% render 'hero',
              type: 'single',
              classname: customclass,
              desktop_text_horizontal_position: block.settings.desktop_text_horizontal_position,
              desktop_text_vertical_position: block.settings.desktop_text_vertical_position,
              mobile_text_horizontal_position: block.settings.mobile_text_horizontal_position,
              mobile_text_vertical_position: block.settings.mobile_text_vertical_position,
              desktop_image: block.settings.desktop_image,
              mobile_image: block.settings.mobile_image,
              heading: block.settings.heading,
              text: block.settings.text,
              button_label: block.settings.button_label,
              button_link: block.settings.button_link,
              heading_disable_on_mobile: block.settings.heading_disable_on_mobile,
              text_disable_on_mobile: block.settings.text_disable_on_mobile,
              button_disable_on_mobile: block.settings.button_disable_on_mobile,
              button_select: block.settings.button_select,
              second_button_select: block.settings.second_button_select,
              second_button_label: block.settings.second_button_label,
              second_button_link: block.settings.second_button_link,
              button_disable_on_mobile_second: block.settings.button_disable_on_mobile_second,
              disable_on_mobile: block.settings.disable_on_mobile,
              subheading: block.settings.subheading,
              subheading_disable_on_mobile: block.settings.subheading_disable_on_mobile,
              placeholder: 'hero-apparel-3',
              section_link: block.settings.button_link,
              lcp_optimized: forloop.first
            %}
          </div>
        {%- endfor -%}
      </div>

        <div class="swiper-button-next wt-slider__nav-btn wt-slider__nav-next">
          {% render 'icons', id: 'arrow-right' %}
        </div>
        <div class="swiper-button-prev wt-slider__nav-btn wt-slider__nav-prev">
          {% render 'icons', id: 'arrow-left' %}
        </div>
        <div
          class="swiper-pagination wt-slider__pagination {% if section.settings.auto-rotate %}swiper-pagination--autoplay{% endif %}"
        ></div>
    </div>
    {% if section.settings.cursor_navigation %}
      <div class="wt-slideshow-cursor" aria-hidden="true">
        <div class="wt-slideshow-cursor__inner">
          <span class="wt-slideshow-cursor__icon wt-slideshow-cursor__icon--prev">
            {% render 'icons', id: 'arrow-left' %}
          </span>
          <span class="wt-slideshow-cursor__icon wt-slideshow-cursor__icon--next">
            {% render 'icons', id: 'arrow-right' %}
          </span>
        </div>
      </div>
    {% endif %}
  </slideshow-section>

  <script type="module" src="{{ 'slider.js' | asset_url }}" defer="defer"></script>

  {%- if request.design_mode -%}
    <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.slideshow.name",
  "tag": "section",
  "class": "slideshow-section wt-shopify-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.global.general"
    },
    {
      "type": "checkbox",
      "id": "advanced_heading",
      "label": "t:sections.global.advanced_heading.label",
      "info": "t:sections.global.advanced_heading.info"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "t:sections.settings.settings.heading.label",
      "default": "Slideshow",
      "visible_if": "{{ section.settings.advanced_heading == false }}"
    },
    {
      "type": "richtext",
      "id": "heading_richtext",
      "label": "t:sections.logo-banner.settings.content.headline.label",
      "default": "<h2>Slideshow</h2>",
      "visible_if": "{{ section.settings.advanced_heading == true }}"
    },
    {
      "type": "checkbox",
      "id": "full-width-enabled",
      "label": "t:sections.settings.settings.section-full-width.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "auto-rotate",
      "label": "t:sections.slideshow.settings.slide.auto-rotate.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "cursor_navigation",
      "label": "t:sections.slideshow.settings.slide.cursor_navigation.label",
      "default": false
    },
    {
      "type": "range",
      "id": "cursor_size",
      "min": 32,
      "max": 80,
      "step": 4,
      "default": 44,
      "unit": "px",
      "label": "t:sections.slideshow.settings.slide.cursor_size.label",
      "visible_if": "{{ section.settings.cursor_navigation }}"
    },
    {
      "type": "header",
      "content": "t:sections.global.section-height"
    },
    {
      "type": "radio",
      "id": "slide_height",
      "label": "t:sections.slideshow.settings.slide.slide_height.default.label",
      "options": [
        {
          "value": "adapt_to_first_image",
          "label": "t:sections.slideshow.settings.slide.slide_height.adapt_to_first_image.label"
        },
        {
          "value": "fixed_height",
          "label": "t:sections.slideshow.settings.slide.slide_height.fixed_height.label"
        }
      ],
      "default": "fixed_height"
    },
    {
      "type": "range",
      "id": "desktop_fixed_height",
      "min": 200,
      "max": 1000,
      "unit": "px",
      "step": 20,
      "default": 320,
      "label": "t:sections.slideshow.settings.slide.desktop_fixed_height.label",
      "info": "t:sections.background-video.settings.original_ratio.option__1.info"
    },
    {
      "type": "range",
      "id": "mobile_fixed_height",
      "min": 200,
      "max": 1000,
      "unit": "px",
      "step": 20,
      "default": 460,
      "label": "t:sections.slideshow.settings.slide.mobile_fixed_height.label",
      "info": "t:sections.background-video.settings.original_ratio.option__1.info"
    },
    {
      "type": "header",
      "content": "t:sections.global.colors",
      "info": "t:sections.global.colors-info"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "t:sections.settings.settings.heading-color.label"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.settings.settings.text-color.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.settings.settings.background-color.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.mobile_version"
    },
    {
      "type": "checkbox",
      "id": "out_hero_mobile",
      "label": "t:sections.slideshow.settings.slide.heading_disable_on_mobile.label",
      "default": false,
      "info": "t:sections.slideshow.settings.slide.heading_disable_on_mobile.info"
    },
    {
      "type": "header",
      "content": "t:sections.global.section_spacing"
    },
    {
      "type": "range",
      "id": "margin-top",
      "min": 0,
      "max": 100,
      "unit": "px",
      "step": 4,
      "default": 20,
      "label": "t:sections.settings.settings.distance-top.label"
    },
    {
      "type": "range",
      "id": "margin-bottom",
      "min": 0,
      "max": 100,
      "unit": "px",
      "step": 4,
      "default": 20,
      "label": "t:sections.settings.settings.distance-bottom.label",
      "info": "t:sections.settings.settings.distance-bottom.info"
    },
    {
      "type": "checkbox",
      "id": "show_mobile_spacing",
      "label": "t:sections.settings.settings.show-mobile-spacing.label"
    },
    {
      "type": "range",
      "id": "margin-top-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-top-mobile.label",
      "visible_if": "{{ section.settings.show_mobile_spacing }}"
    },
    {
      "type": "range",
      "id": "margin-bottom-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-bottom-mobile.label",
      "visible_if": "{{ section.settings.show_mobile_spacing }}"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.slideshow.settings.slide.name",
      "limit": 10,
      "settings": [
        {
          "type": "header",
          "content": "t:sections.global.general"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "t:sections.settings.settings.subheading.label",
          "default": "Tell your story"
        },
        {
          "type": "checkbox",
          "id": "subheading_disable_on_mobile",
          "label": "t:sections.global.disable_on_mobile",
          "default": false
        },
        {  
          "type": "checkbox",
          "id": "subheading_advanced_settings",
          "label": "t:sections.global.subheading_advanced_settings",
          "info": "t:sections.global.subheading_advanced_settings_info",
          "default": false
        },
        {
          "type": "select",
          "id": "subheading_text_style",
          "options": [
            {
              "value": "subtitle",
              "label": "t:sections.global.text_style_subtitle"
            },
            {
              "value": "body",
              "label": "t:sections.global.text_style_body"
            }
          ],
          "default": "subtitle",
          "label": "t:sections.global.text_style_name",
          "visible_if": "{{ block.settings.subheading_advanced_settings }}"
        },
        {
          "type": "checkbox",
          "id": "text_uppercase",
          "label": "t:sections.settings.settings.text_uppercase.label",
          "default": false,
          "visible_if": "{{ block.settings.subheading_advanced_settings }}"
        },
        {
          "type": "range",
          "id": "letter_spacing",
          "min": 0,
          "max": 3,
          "step": 0.1,
          "default": 1,
          "unit": "px",
          "label": "t:sections.settings.settings.letter_spacing.label",
          "visible_if": "{{ block.settings.subheading_advanced_settings }}"
        },
        {
          "type": "range",
          "id": "size_text_desktop",
          "min": 50,
          "max": 300,
          "step": 10,
          "default": 100,
          "unit": "%",
          "label": "t:sections.settings.settings.size-text.label",
          "visible_if": "{{ block.settings.subheading_advanced_settings }}"
        },
        {
          "type": "range",
          "id": "size_text_mobile",
          "min": 50,
          "max": 300,
          "step": 10,
          "default": 100,
          "unit": "%",
          "label": "t:sections.settings.settings.size-text-mobile.label",
          "visible_if": "{{ block.settings.subheading_advanced_settings }}"
        },
        {
          "type": "textarea",
          "id": "heading",
          "default": "Image slide",
          "label": "t:sections.settings.settings.heading.label"
        },
        {
          "type": "checkbox",
          "id": "heading_disable_on_mobile",
          "label": "t:sections.global.heading_disable_on_mobile",
          "default": false
        },
        {
          "type": "range",
          "id": "size_heading",
          "min": 50,
          "max": 500,
          "step": 10,
          "default": 100,
          "label": "t:sections.settings.settings.size-heading.label",
          "unit": "%"
        },
        {
          "type": "range",
          "id": "size_heading_mobile",
          "min": 80,
          "max": 300,
          "step": 10,
          "default": 100,
          "label": "t:sections.settings.settings.size-heading-mobile.label",
          "unit": "%"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Tell your brand's story through images</p>",
          "label": "t:sections.settings.settings.text.label"
        },
        {
          "type": "checkbox",
          "id": "text_disable_on_mobile",
          "label": "t:sections.global.disable_on_mobile",
          "default": false
        },
        {
          "type": "select",
          "id": "text_style",
          "options": [
            {
              "value": "subtitle",
              "label": "t:sections.image-with-text.text.settings.text_style.settings.options__1.label"
            },
            {
              "value": "body",
              "label": "t:sections.image-with-text.text.settings.text_style.settings.options__2.label"
            }
          ],
          "default": "body",
          "label": "t:sections.image-with-text.text.settings.text_style.name"
        },
        {
          "type": "header",
          "content": "t:sections.global.button_1"
        },
        {
          "type": "select",
          "id": "button_select",
          "options": [
            {
              "value": "primary",
              "label": "t:sections.settings.settings.button_select.primary.label"
            },
            {
              "value": "secondary",
              "label": "t:sections.settings.settings.button_select.secondary.label"
            },
            {
              "value": "link",
              "label": "t:sections.settings.settings.button_select.link.label"
            }
          ],
          "default": "primary",
          "label": "t:sections.settings.settings.button_select.default.label"
        },
        {
          "id": "button_label",
          "type": "text",
          "default": "Button label",
          "label": "t:sections.settings.settings.button_label.label"
        },
        {
          "type": "checkbox",
          "id": "button_disable_on_mobile",
          "label": "t:sections.global.disable_on_mobile",
          "default": false
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:sections.settings.settings.link.label"
        },
        {
          "type": "header",
          "content": "t:sections.global.button_2"
        },
        {
          "type": "select",
          "id": "second_button_select",
          "options": [
            {
              "value": "primary",
              "label": "t:sections.settings.settings.button_select.primary.label"
            },
            {
              "value": "secondary",
              "label": "t:sections.settings.settings.button_select.secondary.label"
            },
            {
              "value": "link",
              "label": "t:sections.settings.settings.button_select.link.label"
            }
          ],
          "default": "primary",
          "label": "t:sections.settings.settings.button_select.default.label"
        },
        {
          "id": "second_button_label",
          "type": "text",
          "label": "t:sections.settings.settings.button_label.label"
        },
        {
          "type": "checkbox",
          "id": "button_disable_on_mobile_second",
          "label": "t:sections.global.disable_on_mobile",
          "default": false
        },
        {
          "type": "url",
          "id": "second_button_link",
          "label": "t:sections.settings.settings.link.label"
        },
        {
          "type": "header",
          "content": "t:sections.global.colors"
        },
        {
          "type": "color",
          "id": "color-body-text",
          "label": "t:sections.settings.settings.text-color.label"
        },
        {
          "type": "color",
          "id": "color-overlay",
          "label": "t:sections.settings.settings.background-color.label"
        },
        {
          "type": "range",
          "id": "color-overlay-opacity",
          "min": 0,
          "max": 100,
