{% assign has_content = false %}
{%- for block in section.blocks -%}
  {% if block.type == 'text' and block.settings.text != '' %}
    {% assign has_content = true %}
    {% break %}
  {% endif %}
  {% if block.type == 'heading' and block.settings.heading != '' %}
    {% assign has_content = true %}
    {% break %}
  {% endif %}
{% endfor %}

{% assign background_rgb = section.settings.background_color | color_to_rgb %}
{% assign text_rgb = section.settings['color-body-text'] | color_to_rgb %}

{% if request.design_mode or has_content %}
  <style>
        [data-section-id="{{ section.id }}"]
        {
            {% if section.settings.background_color != blank and section.settings.background_color != 'transparent' and background_rgb != 'rgba(0, 0, 0, 0.0)' %}
              --color-custom-background: {{ section.settings.background_color }};
            {% endif %}

            {% if section.settings['color-body-text'] != blank and section.settings['color-body-text'] != 'transparent' and text_rgb != 'rgba(0, 0, 0, 0.0)' %}
              --color-custom-text: {{ section.settings.color-body-text }};
            {% endif %}

            {% if section.settings.margin-top %}
                --section-gap-top: {{ section.settings.margin-top }}px;
            {% endif %}

            {% if section.settings.margin-bottom %}
                --section-gap-bottom: {{ section.settings.margin-bottom }}px;
            {% endif %}

      {%- if section.settings.show_mobile_spacing -%}
          --section-gap-top-mobile: {{ section.settings.margin-top-mobile }}px;
      {%- endif -%}

      {%- if section.settings.show_mobile_spacing -%}
          --section-gap-bottom-mobile: {{ section.settings.margin-bottom-mobile }}px;
      {%- endif -%}

        }

    {%- for block in section.blocks -%}
        [data-block-id="{{ block.id }}"]
        {

              --font-headline-scale-desk: {{ block.settings.size_heading | divided_by: 100.0 }};

              --font-headline-scale: {{ block.settings.size_heading_mobile | divided_by: 100.0 }};

              --font-base-line-height: {{ block.settings.line_height }};

              --font-base-transform: {{ block.settings.font_uppercase }};

        {% if block.type == 'subheading' and block.settings.subheading_advanced_settings %}
          --font-subheading-scale: {{ block.settings.size_text_mobile | divided_by: 100.0 }};
          --font-subheading-scale-desk: {{ block.settings.size_text_desktop | divided_by: 100.0 }};
          --subheading-letter-spacing: {{ block.settings.letter_spacing }}px;
          {% if block.settings.text_uppercase %}
            --subheading-text-transform: uppercase;
          {% endif %}
          {% if block.settings.text_style == 'body' %}
            --subheading-font-family: var(--font-base);
          {% endif %}
        {% endif %}
        }
    {%- endfor -%}
  </style>

  <div
    data-section-id="{{ section.id }}"
    class="rich-text"
  >
    <div class="hero__wrapper">
      {% render 'hero',
        type: 'blocks',
        desktop_text_horizontal_position: section.settings.desktop_text_horizontal_position,
        desktop_text_vertical_position: 'center',
        blocks: section.blocks,
        rich_text_with_image: true
      %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "t:sections.rich-text-with-image.name",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "desktop_text_horizontal_position",
      "options": [
        {
          "value": "left",
          "label": "t:sections.rich-text-with-image.settings.desktop_text_horizontal_position.left.label"
        },
        {
          "value": "center",
          "label": "t:sections.rich-text-with-image.settings.desktop_text_horizontal_position.center.label"
        },
        {
          "value": "right",
          "label": "t:sections.rich-text-with-image.settings.desktop_text_horizontal_position.right.label"
        }
      ],
      "default": "center",
      "label": "t:sections.rich-text-with-image.settings.desktop_text_horizontal_position.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.colors",
      "info": "t:sections.global.colors-info"
    },
    {
      "type": "color",
      "id": "color-body-text",
      "label": "t:sections.settings.settings.text-color.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.settings.settings.background-color.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.section_spacing"
    },
    {
      "type": "range",
      "id": "margin-top",
      "min": 0,
      "max": 100,
      "unit": "px",
      "step": 4,
      "default": 20,
      "label": "t:sections.settings.settings.distance-top.label"
    },
    {
      "type": "range",
      "id": "margin-bottom",
      "min": 0,
      "max": 100,
      "unit": "px",
      "step": 4,
      "default": 20,
      "label": "t:sections.settings.settings.distance-bottom.label",
      "info": "t:sections.settings.settings.distance-bottom.info"
    },
    {
      "type": "checkbox",
      "id": "show_mobile_spacing",
      "label": "t:sections.settings.settings.show-mobile-spacing.label"
    },
    {
      "type": "range",
      "id": "margin-top-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-top-mobile.label",
      "visible_if": "{{ section.settings.show_mobile_spacing }}"
    },
    {
      "type": "range",
      "id": "margin-bottom-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-bottom-mobile.label",
      "visible_if": "{{ section.settings.show_mobile_spacing }}"
    }
  ],
  "blocks": [
    {
      "type": "subheading",
      "name": "t:sections.global.subheading_block_name",
      "settings": [
        {
          "type": "text",
          "id": "subheading",
          "label": "t:sections.settings.settings.subheading.label",
          "default": "Tell your story"
        },
        {
          "type": "checkbox",
          "id": "subheading_disable_on_mobile",
          "label": "t:sections.global.disable_on_mobile",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "subheading_advanced_settings",
          "label": "t:sections.global.subheading_advanced_settings",
          "info": "t:sections.global.subheading_advanced_settings_info",
          "default": false
        },
        {
          "type": "select",
          "id": "text_style",
          "options": [
            {
              "value": "subtitle",
              "label": "t:sections.global.text_style_subtitle"
            },
            {
              "value": "body",
              "label": "t:sections.global.text_style_body"
            }
          ],
          "default": "subtitle",
          "label": "t:sections.global.text_style_name",
          "visible_if": "{{ block.settings.subheading_advanced_settings }}"
        },
        {
          "type": "checkbox",
          "id": "text_uppercase",
          "label": "t:sections.settings.settings.text_uppercase.label",
          "default": false,
          "visible_if": "{{ block.settings.subheading_advanced_settings }}"
        },
        {
          "type": "range",
          "id": "letter_spacing",
          "min": 0,
          "max": 3,
          "step": 0.1,
          "default": 1,
          "unit": "px",
          "label": "t:sections.settings.settings.letter_spacing.label",
          "visible_if": "{{ block.settings.subheading_advanced_settings }}"
        },
        {
          "type": "header",
          "content": "t:sections.global.desktop_version",
          "visible_if": "{{ block.settings.subheading_advanced_settings }}"
        },
        {
          "type": "range",
          "id": "size_text_desktop",
          "min": 50,
          "max": 300,
          "step": 10,
          "default": 100,
          "unit": "%",
          "label": "t:sections.settings.settings.size-text.label",
          "visible_if": "{{ block.settings.subheading_advanced_settings }}"
        },
        {
          "type": "header",
          "content": "t:sections.global.mobile_version",
          "visible_if": "{{ block.settings.subheading_advanced_settings }}"
        },
        {
          "type": "range",
          "id": "size_text_mobile",
          "min": 50,
          "max": 300,
          "step": 10,
          "default": 100,
          "unit": "%",
          "label": "t:sections.settings.settings.size-text-mobile.label",
          "visible_if": "{{ block.settings.subheading_advanced_settings }}"
        }
      ]
    },
    {
      "type": "heading",
      "name": "t:sections.rich-text-with-image.blocks.heading.name",
      "settings": [
        {
          "type": "richtext",
          "id": "subheading",
          "default": "<p>Customize Your Visual Layout</p>",
          "label": "t:sections.settings.settings.subheading.label"
        },
        {
          "type": "select",
          "id": "font_uppercase",
          "default": "none",
          "options": [
            {
              "value": "none",
              "label": "none"
            },
            {
              "value": "uppercase",
              "label": "Uppercase"
            }
          ],
          "label": "t:settings_schema.typography.settings.type_body_font_uppercase.label"
        },
        {
          "type": "checkbox",
          "id": "disable_on_mobile",
          "label": "t:sections.global.disable_on_mobile",
          "default": false
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.rich-text-with-image.blocks.text.name",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "default": "Type PICTURE1 to insert the first icon – place it where you want a visual cue. Insert PICTURE2 by typing it where a second visual element is needed. Use PICTURE3 for adding a third icon – ensure it has its own space.",
          "label": "t:sections.settings.settings.text.label"
        },
        {
          "type": "select",
          "id": "font_uppercase",
          "default": "none",
          "options": [
            {
              "value": "none",
              "label": "none"
            },
            {
              "value": "uppercase",
              "label": "Uppercase"
            }
          ],
          "label": "t:settings_schema.typography.settings.type_body_font_uppercase.label"
        },
        {
          "type": "checkbox",
          "id": "disable_on_mobile",
          "label": "t:sections.global.disable_on_mobile",
          "default": false
        },
        {
          "type": "range",
          "id": "size_heading",
          "min": 50,
          "max": 500,
          "step": 10,
          "default": 100,
          "label": "t:sections.settings.settings.size-heading.label",
          "unit": "%"
        },
        {
          "type": "range",
          "id": "size_heading_mobile",
          "min": 80,
          "max": 300,
          "step": 10,
          "default": 100,
          "label": "t:sections.settings.settings.size-heading-mobile.label",
          "unit": "%"
        },
        {
          "type": "range",
          "id": "line_height",
          "min": 1,
          "max": 2,
          "step": 0.1,
          "default": 1.5,
          "label": "t:settings_schema.typography.settings.typo_line_height.label"
        },
        {
          "type": "image_picker",
          "id": "picture1",
          "label": "t:sections.rich-text-with-image.blocks.heading.settings.picture1.label",
          "info": "t:sections.rich-text-with-image.blocks.heading.settings.picture1.info"
        },
        {
          "type": "url",
          "id": "button_link1",
          "label": "t:sections.rich-text-with-image.blocks.heading.settings.link1.label"
        },
        {
          "type": "image_picker",
          "id": "picture2",
          "label": "t:sections.rich-text-with-image.blocks.heading.settings.picture2.label",
          "info": "t:sections.rich-text-with-image.blocks.heading.settings.picture2.info"
        },
        {
          "type": "url",
          "id": "button_link2",
          "label": "t:sections.rich-text-with-image.blocks.heading.settings.link2.label"
        },
        {
          "type": "image_picker",
          "id": "picture3",
          "label": "t:sections.rich-text-with-image.blocks.heading.settings.picture3.label",
          "info": "t:sections.rich-text-with-image.blocks.heading.settings.picture3.info"
        },
        {
          "type": "url",
          "id": "button_link3",
          "label": "t:sections.rich-text-with-image.blocks.heading.settings.link3.label"
        },
        {
          "type": "image_picker",
          "id": "picture4",
          "label": "t:sections.rich-text-with-image.blocks.heading.settings.picture4.label",
          "info": "t:sections.rich-text-with-image.blocks.heading.settings.picture4.info"
        },
        {
          "type": "url",
          "id": "button_link4",
          "label": "t:sections.rich-text-with-image.blocks.heading.settings.link4.label"
        }
      ]
    },
    {
      "type": "custom_liquid",
      "name": "t:blocks.custom_liquid.name",
      "settings": [
        {
          "type": "liquid",
          "id": "liquid_code",
          "label": "t:blocks.custom_liquid.settings.liquid_code.label",
          "info": "t:blocks.custom_liquid.settings.liquid_code.info"
        }
      ]
    },
    {
      "type": "ui_spacer",
      "name": "t:blocks.ui_spacer.name",
      "settings": [
        {
          "type": "range",
          "id": "spacer_desktop_height",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 32,
          "label": "t:blocks.ui_spacer.settings.spacer_desktop_height.label",
          "unit": "px"
        },
        {
          "type": "range",
          "id": "spacer_mobile_height",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 16,
          "label": "t:blocks.ui_spacer.settings.spacer_mobile_height.label",
          "unit": "px"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.rich-text-with-image.presets.name",
      "category": "t:sections.categories.text",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "text"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
