{{ 'section-featured-blog-post.css' | asset_url | stylesheet_tag }}

{% liquid
  if section.settings.article != blank
    assign article = section.settings.article
  else
    assign article = section.settings.blog.articles.first
  endif
%}

{% assign background_section_rgb = section.settings['section-color-overlay'] | color_to_rgb %}
{% assign background_rgb = section.settings['color-overlay'] | color_to_rgb %}
{% assign text_rgb = section.settings['color-body-text'] | color_to_rgb %}

<style>
  section[id="shopify-section-{{ section.id }}"] {
    {% if section.settings['section-color-overlay'] != blank and section.settings['section-color-overlay'] != 'transparent' and background_section_rgb != 'rgba(0, 0, 0, 0.0)' %}
      --color-overlay-rgb: {{ section.settings['section-color-overlay'] | color_to_rgb | remove: 'rgb(' | remove: 'rgba(' | remove: ')' }};
      --color-overlay-opacity: {{ section.settings['section-color-overlay-opacity'] | divided_by: 100.0 }};
    {% else %}
      --color-overlay-rgb: 0, 0, 0;
      --color-overlay-opacity: 0;
    {% endif %}
  }

  [data-section-id="{{ section.id }}"] {
    {% if section.settings['color-overlay'] != blank and section.settings['color-overlay'] != 'transparent' and background_rgb != 'rgba(0, 0, 0, 0.0)' %}
      --color-overlay-rgb: {{ section.settings['color-overlay'] | color_to_rgb | remove: 'rgb(' | remove: 'rgba(' | remove: ')' }};
      --color-overlay-opacity: {{ section.settings['color-overlay-opacity'] | divided_by: 100.0 }};
    {% else %}
      --color-overlay-rgb: 0, 0, 0;
      --color-overlay-opacity: 0;
    {% endif %}

    {% if section.settings['full-width-enabled'] %}
      --border-radius: 0;
    {% endif %}

    {% if section.settings['margin-top'] %}
      --section-gap-top: {{ section.settings['margin-top'] }}px;
    {% endif %}

    {% if section.settings['margin-bottom'] %}
      --section-gap-bottom: {{ section.settings['margin-bottom'] }}px;
    {% endif %}

      {%- if section.settings.show_mobile_spacing -%}
          --section-gap-top-mobile: {{ section.settings.margin-top-mobile }}px;
      {%- endif -%}

      {%- if section.settings.show_mobile_spacing -%}
          --section-gap-bottom-mobile: {{ section.settings.margin-bottom-mobile }}px;
      {%- endif -%}

    --desktop-percentage-image-width: {{ section.settings['desktop-percentage-image-width'] }}%;
    --font-headline-scale-desk: {{ section.settings.size_heading | divided_by: 100.0 }};
    --font-headline-scale: {{ section.settings.size_heading_mobile | divided_by: 100.0 }};

    {% if section.settings.slide_height == 'fixed_height' %}
      --section-height: {{ section.settings.mobile_fixed_height }}px;
      --section-height-desk: {{ section.settings.desktop_fixed_height }}px;
    {% endif %}

    {% if section.settings.slide_height == 'adapt_to_first_image' and article.image %}
      --first-slide-ratio: {{ article.image.aspect_ratio | default: 1 }};
      --first-slide-ratio-desk: {{ article.image.aspect_ratio | default: 2.5 }};
    {% endif %}
  }

  {% if section.settings['color-overlay'] == blank or section.settings['color-overlay'] == 'transparent' or background_rgb == 'rgba(0, 0, 0, 0.0)' %}
  [data-section-id="{{ section.id }}"] .hero__pic-container,
  [data-section-id="{{ section.id }}"] .wt-video__movie {
    border-radius: var(--border-radius);
    overflow: hidden;
  }
  {% endif %}

  [data-section-id="{{ section.id }}"] .hero {
    {% if section.settings['color-body-text'] != blank and section.settings['color-body-text'] != 'transparent' and text_rgb != 'rgba(0, 0, 0, 0.0)' %}
      --color-custom-text: {{ section.settings['color-body-text'] }};
    {% endif %}
  }
</style>

{% if section.settings.layout == 'text_first' %}
  {% assign customclass = 'hero--grid hero--grid--rev' %}
{% else %}
  {% assign customclass = 'hero--grid' %}
{% endif %}

{% if section.settings['full-width-enabled'] %}
  {% assign customwrapperclass = 'hero__wrapper--full' %}
{% else %}
  {% assign customwrapperclass = 'hero__wrapper' %}
{% endif %}

{% liquid
  if article
    assign article_heading = article.title
    assign article_url = article.url

    assign article_text = blank

    if section.settings.show_date or section.settings.show_author
      assign article_meta = blank
      if section.settings.show_date
        assign article_meta = article.published_at | date: '%B %d, %Y'
      endif
      if section.settings.show_author
        if article_meta != blank
          assign article_meta = article_meta | append: ' · ' | append: article.author
        else
          assign article_meta = article.author
        endif
      endif
      assign article_text = '<span class="featured-blog-post__meta">' | append: article_meta | append: '</span>'
    endif

    if section.settings.show_excerpt and article.excerpt != blank
      assign article_text = article_text | append: article.excerpt
    endif
  else
    assign article_heading = 'sections.featured_blog.onboarding_title' | t
    assign article_text = 'sections.featured_blog.onboarding_content' | t
    assign article_url = '#'
  endif
%}

<div
  data-section-id="{{ section.id }}"
  data-height="{{ section.settings.slide_height }}"
  class="{{ customwrapperclass }} {% if section.settings.content_below_image_desktop %} hero__wrapper--content-below-desktop {% endif %} {% if settings.animations and section.settings['full-width-enabled'] != true %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
>
  <div class="{% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
    {% render 'hero',
      classname: customclass,
      desktop_text_horizontal_position: section.settings.desktop_text_horizontal_position,
      desktop_text_vertical_position: section.settings.desktop_text_vertical_position,
      mobile_text_horizontal_position: section.settings.mobile_text_horizontal_position,
      mobile_text_vertical_position: section.settings.mobile_text_vertical_position,
      desktop_image: article.image,
      mobile_image: article.image,
      placeholder: 'detailed-apparel-1',
      heading: article_heading,
      text: article_text,
      button_label: section.settings.button_label,
      button_link: article_url,
      button_select: section.settings.button_select,
      link_only_on_button: true
    %}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.featured-blog-post.name",
  "tag": "section",
  "class": "section-featured-blog-post wt-shopify-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.global.general"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "t:sections.featured-blog-post.settings.blog.label",
      "info": "t:sections.featured-blog-post.settings.blog.info"
    },
    {
      "type": "article",
      "id": "article",
      "label": "t:sections.featured-blog-post.settings.article.label",
      "info": "t:sections.featured-blog-post.settings.article.info"
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "t:sections.featured-blog-post.settings.show_excerpt.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": false,
      "label": "t:sections.featured-blog.blocks.title.settings.show_date.label"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "default": false,
      "label": "t:sections.featured-blog.blocks.title.settings.show_author.label"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "image_first",
          "label": "t:sections.image-with-text.settings.layout.options__1.label"
        },
        {
          "value": "text_first",
          "label": "t:sections.image-with-text.settings.layout.options__2.label"
        }
      ],
      "default": "image_first",
      "label": "t:sections.image-with-text.settings.layout.label",
      "info": "t:sections.image-with-text.settings.layout.info"
    },
    {
      "type": "range",
      "id": "desktop-percentage-image-width",
      "min": 30,
      "max": 70,
      "step": 1,
      "unit": "%",
      "default": 50,
      "label": "t:sections.image-with-text.settings.desktop-percentage-image-width.label"
    },
    {
      "type": "checkbox",
      "id": "full-width-enabled",
      "label": "t:sections.settings.settings.section-full-width.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "content_below_image_desktop",
      "label": "t:sections.featured-blog-post.settings.content_below_image_desktop.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.global.button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.featured-blog-post.settings.button_label.label",
      "default": "Read more"
    },
    {
      "type": "select",
      "id": "button_select",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.settings.settings.button_select.primary.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.settings.settings.button_select.secondary.label"
        },
        {
          "value": "link",
          "label": "t:sections.settings.settings.button_select.link.label"
        }
      ],
      "default": "primary",
      "label": "t:sections.settings.settings.button_select.default.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.section-height"
    },
    {
      "type": "radio",
      "id": "slide_height",
      "label": "t:sections.slideshow.settings.slide.slide_height.default.label",
      "options": [
        {
          "value": "adapt_to_first_image",
          "label": "t:sections.slideshow.settings.slide.slide_height.adapt_to_first_image.label"
        },
        {
          "value": "fixed_height",
          "label": "t:sections.slideshow.settings.slide.slide_height.fixed_height.label"
        }
      ],
      "default": "fixed_height"
    },
    {
      "type": "range",
      "id": "desktop_fixed_height",
      "min": 200,
      "max": 1000,
      "unit": "px",
      "step": 20,
      "default": 320,
      "label": "t:sections.slideshow.settings.slide.desktop_fixed_height.label",
      "info": "t:sections.background-video.settings.original_ratio.option__1.info"
    },
    {
      "type": "range",
      "id": "mobile_fixed_height",
      "min": 200,
      "max": 1000,
      "unit": "px",
      "step": 20,
      "default": 460,
      "label": "t:sections.slideshow.settings.slide.mobile_fixed_height.label",
      "info": "t:sections.background-video.settings.original_ratio.option__1.info"
    },
    {
      "type": "header",
      "content": "t:sections.global.colors",
      "info": "t:sections.global.colors-info"
    },
    {
      "type": "color",
      "id": "section-color-overlay",
      "label": "t:sections.global.section-background-color"
    },
    {
      "type": "range",
      "id": "section-color-overlay-opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "label": "t:sections.settings.settings.background-opacity.label"
    },
    {
      "type": "color",
      "id": "color-body-text",
      "label": "t:sections.settings.settings.text-color.label"
    },
    {
      "type": "color",
      "id": "color-overlay",
      "label": "t:sections.settings.settings.background-container-color.label"
    },
    {
      "type": "range",
      "id": "color-overlay-opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "label": "t:sections.settings.settings.background-opacity.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.desktop_version"
    },
    {
      "type": "range",
      "id": "size_heading",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 100,
      "label": "t:sections.settings.settings.size-heading.label",
      "unit": "%"
    },
    {
      "type": "select",
      "id": "desktop_text_vertical_position",
      "options": [
        {
          "value": "top",
          "label": "t:sections.image-banner.settings.desktop_text_vertical_position.top.label"
        },
        {
          "value": "center",
          "label": "t:sections.image-banner.settings.desktop_text_vertical_position.center.label"
        },
        {
          "value": "bottom",
          "label": "t:sections.image-banner.settings.desktop_text_vertical_position.bottom.label"
        }
      ],
      "default": "center",
      "label": "t:sections.image-banner.settings.desktop_text_vertical_position.label"
    },
    {
      "type": "select",
      "id": "desktop_text_horizontal_position",
      "options": [
        {
          "value": "left",
          "label": "t:sections.image-banner.settings.desktop_text_horizontal_position.left.label"
        },
        {
          "value": "center",
          "label": "t:sections.image-banner.settings.desktop_text_horizontal_position.center.label"
        },
        {
          "value": "right",
          "label": "t:sections.image-banner.settings.desktop_text_horizontal_position.right.label"
        }
      ],
      "default": "center",
      "label": "t:sections.image-banner.settings.desktop_text_horizontal_position.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.mobile_version"
    },
    {
      "type": "range",
      "id": "size_heading_mobile",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 100,
      "label": "t:sections.settings.settings.size-heading-mobile.label",
      "unit": "%"
    },
    {
      "type": "select",
      "id": "mobile_text_horizontal_position",
      "options": [
        {
          "value": "left",
          "label": "t:sections.image-banner.settings.mobile_text_horizontal_position.left.label"
        },
        {
          "value": "center",
          "label": "t:sections.image-banner.settings.mobile_text_horizontal_position.center.label"
        },
        {
          "value": "right",
          "label": "t:sections.image-banner.settings.mobile_text_horizontal_position.right.label"
        }
      ],
      "default": "center",
      "label": "t:sections.image-banner.settings.mobile_text_vertical_position.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.section_spacing"
    },
    {
      "type": "range",
      "id": "margin-top",
      "min": 0,
      "max": 100,
      "unit": "px",
      "step": 4,
      "default": 20,
      "label": "t:sections.settings.settings.distance-top.label"
    },
    {
      "type": "range",
      "id": "margin-bottom",
      "min": 0,
      "max": 100,
      "unit": "px",
      "step": 4,
      "default": 20,
      "label": "t:sections.settings.settings.distance-bottom.label",
      "info": "t:sections.settings.settings.distance-bottom.info"
    },
    {
      "type": "checkbox",
      "id": "show_mobile_spacing",
      "label": "t:sections.settings.settings.show-mobile-spacing.label"
    },
    {
      "type": "range",
      "id": "margin-top-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-top-mobile.label",
      "visible_if": "{{ section.settings.show_mobile_spacing }}"
    },
    {
      "type": "range",
      "id": "margin-bottom-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-bottom-mobile.label",
      "visible_if": "{{ section.settings.show_mobile_spacing }}"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured-blog-post.presets.name",
      "category": "t:sections.categories.blog"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}