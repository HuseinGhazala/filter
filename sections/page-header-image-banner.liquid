{% if template == 'index' %}
  {% assign text-container_rgb = section.settings['text-container-color'] | color_to_rgb %}
  {% assign text_rgb = section.settings['color-body-text'] | color_to_rgb %}
  {% assign out_background_rgb = section.settings.out-background-color | color_to_rgb %}
  {% assign out_text_rgb = section.settings.out-text-color | color_to_rgb %}

  {{ 'section-video.css' | asset_url | stylesheet_tag }}

  <style>
    section[id="shopify-section-{{ section.id }}"]{

        --color-overlay-opacity: 0;

    {% if section.settings['text-container-color'] != blank and section.settings['text-container-color'] != 'transparent' and text-container_rgb != 'rgba(0, 0, 0, 0.0)' %}
        --text-container-color: {{ section.settings.text-container-color | color_to_rgb | remove: 'rgb(' | remove: ')' }};
        --text-container-opacity: {{ section.settings.color-overlay-opacity | divided_by: 100.0 }};
    {% else %}
        --text-container-opacity: 0;
    {% endif %}

    {% if section.settings['color-body-text'] != blank and section.settings['color-body-text'] != 'transparent' and text_rgb != 'rgba(0, 0, 0, 0.0)' %}
        --color-custom-text: {{ section.settings.color-body-text }};
    {% endif %}

    {% if section.settings.out_hero_mobile %}
      {% if section.settings['out-background-color'] != blank and section.settings['out-background-color'] != 'transparent' and out_background_rgb != 'rgba(0, 0, 0, 0.0)' %}
        --slide-out-background-color: {{ section.settings.out-background-color }};
      {% endif %}

      {% if section.settings['out-text-color'] != blank and section.settings['out-text-color'] != 'transparent' and out_text_rgb != 'rgba(0, 0, 0, 0.0)' %}
        --slide-out-text-color: {{ section.settings.out-text-color }};
      {% endif %}
    {% endif %}
    }

    [data-section-id="{{ section.id }}"]
    {
    {% if section.settings.full-width-enabled %}
        --border-radius: 0;
    {% endif %}

    {% if section.settings.slide_height == 'fixed_height' %}
        --section-height: {{ section.settings.mobile_fixed_height }}px;
        --section-height-desk: {{ section.settings.desktop_fixed_height }}px;
    {% endif %}

    {% if section.settings.slide_height == 'adapt_to_first_image' and section.settings.video_hosted != null %}
        --first-slide-ratio: {{ section.blocks.first.settings.mobile_image.aspect_ratio | default: 1 }};
        --first-slide-ratio-desk: {{ section.blocks.first.settings.desktop_image.aspect_ratio | default: 2.5 }};
    {% endif %}

    {% if section.settings.video_hosted != null and section.settings.slide_height != 'fixed_height' %}
        --section-height: 100vh;
        --section-height-desk: 100vh;
    {% endif %}
    }

    {%- for block in section.blocks -%}
    [data-block-id="{{ block.id }}"]
    {
        --font-headline-scale-desk: {{ block.settings.size_heading | divided_by: 100.0 }};
        --font-headline-scale: {{ block.settings.size_heading_mobile | divided_by: 100.0 }};
        
        {% if block.type == 'icon_with_text' %}
          --icon-height-desktop: {{ block.settings.icon_height_desktop }}px;
          --icon-height: {{ block.settings.icon_height }}px;
          --icon-margin-desktop: {{ block.settings.icon_margin_desktop }}px;
          --icon-margin: {{ block.settings.icon_margin }}px;
          --size-heading-desktop: {{ block.settings.size_heading | divided_by: 100.0 }};
          --size-heading: {{ block.settings.size_heading_mobile | divided_by: 100.0 }};
          --gap: {{ block.settings.gap }}px;
          --margin-top: {{ block.settings.margin_top }}px;
          --margin-bottom: {{ block.settings.margin_bottom }}px;
          --margin-left: {{ block.settings.margin_left }}px;
          --margin-left-desktop: {{ block.settings.margin_left_desktop }}px;

          {% if block.settings.icon_alignment != 'inherit' %}
            --icon-alignment: {{ block.settings.icon_alignment }};
          {% endif %}
          {% if block.settings.icon_alignment_mobile != 'inherit' %}
            --icon-alignment-mobile: {{ block.settings.icon_alignment_mobile }};
          {% endif %}

          {% if block.settings.icon_alignment == "flex-start" %}
            --icon-text-alignment: left;
          {% elsif block.settings.icon_alignment == "flex-end" %}
            --icon-text-alignment: right;
          {% elsif block.settings.icon_alignment == "center" %}
            --icon-text-alignment: center;
          {% endif %}

          {% if block.settings.icon_alignment_mobile == "flex-start" %}
            --icon-text-alignment-mobile: left;
          {% elsif block.settings.icon_alignment_mobile == "flex-end" %}
            --icon-text-alignment-mobile: right;
          {% elsif block.settings.icon_alignment_mobile == "center" %}
            --icon-text-alignment-mobile: center;
          {% endif %}
        {% endif %}

        {% if block.type == 'text' and block.settings.text_style == 'subtitle' %}
            --font-base: var(--font-headline);
        {% endif %}

        {% if block.type == 'subheading' and block.settings.subheading_advanced_settings %}
          --font-subheading-scale: {{ block.settings.size_text_mobile | divided_by: 100.0 }};
          --font-subheading-scale-desk: {{ block.settings.size_text_desktop | divided_by: 100.0 }};
          --subheading-letter-spacing: {{ block.settings.letter_spacing }}px;
          {% if block.settings.text_uppercase %}
            --subheading-text-transform: uppercase;
          {% endif %}
          {% if block.settings.text_style == 'body' %}
            --subheading-font-family: var(--font-base);
          {% endif %}
        {% endif %}
    }
    {%- endfor -%}

    {% if section.settings.custom-section-color-text-enabled %}
    .wt-header--transparent.wt-header--v3 {
        --color-transparent-header: {{ section.settings.section-color-body-text }};
    }
    {% endif %}
  </style>

  {% if section.settings.out_hero_mobile %}
    {% assign customclass = 'hero--out-mobile' %}
  {% else %}
    {% assign customclass = '' %}
  {% endif %}

  {% assign width_line = 'hero__wrapper--full' %}

  <script src="{{ 'page-header-image-banner.js' | asset_url }}" defer="defer"></script>

  <page-header-image-banner class="page-header-image-banner {% if section.settings.video_hosted != null %}page-header-image-banner--video{%- endif -%}">
    <div
      data-section-id="{{ section.id }}"
      class="wt-image-banner wt-image-banner--header {{ width_line }} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
    >
      <div class="{% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}" data-height="{{ section.settings.slide_height }}">
        {% render 'hero',
          type: 'blocks',
          classname: customclass,
          desktop_text_horizontal_position: section.settings.desktop_text_horizontal_position,
          desktop_text_vertical_position: section.settings.desktop_text_vertical_position,
          mobile_text_horizontal_position: section.settings.mobile_text_horizontal_position,
          mobile_text_vertical_position: section.settings.mobile_text_vertical_position,
          desktop_image: section.settings.desktop_image,
          mobile_image: section.settings.mobile_image,
          placeholder: 'hero-apparel-1',
          blocks: section.blocks,
          video: section.settings.video_hosted,
          mobile_video: section.settings.video_hosted_mobile,
          lcp_tweak: true
        %}
      </div>
    </div>
  </page-header-image-banner>

  <script>
    (() => {
      const currentSection = document.querySelector('.section-image-banner--header');

      function isValidSectionsOrder() {
        const pageHeader = document.body.querySelector('header.page-header');

        if (pageHeader && currentSection) {
          let sibling = pageHeader.nextElementSibling;
          while (sibling && sibling.tagName.toLowerCase() !== 'section') {
            sibling = sibling.nextElementSibling;
          }
          return sibling === currentSection;
        }
        return false;
      }

      function isTransparentHeaderEnabled() {
        const header = document.querySelector('.wt-header');
        return isValidSectionsOrder() && Boolean(header?.dataset.transparent);
      }

      function calculateOffset() {
        const header = document.querySelector('header');
        const headerHeight = header.offsetHeight;

        const announcement = document.querySelector('.wt-announcement');
        const announcementHeight = announcement ? announcement.offsetHeight : 0;
        const offset = isTransparentHeaderEnabled() ? headerHeight + announcementHeight : 0;

        return offset;
      }

      function setTopMargin() {
        const offset = calculateOffset();
        currentSection.style.marginTop = `-${offset}px`;
      }

      if (isTransparentHeaderEnabled()) {
        setTopMargin();
      }
    })();
  </script>
{% endif %}

