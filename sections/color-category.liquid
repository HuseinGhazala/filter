{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'swiper.css' | asset_url | stylesheet_tag }}
<script type="module" src="{{ 'slider.js' | asset_url }}" defer="defer"></script>

{%- unless settings.quick_add == 'none' -%}
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}




{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: 0px !important;
      padding-bottom: 40px !important;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px !important;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px !important;
    }
  }

  /* ===== Critical layout CSS (inlined to avoid FOUC / element overlap on first paint) ===== */
  .collection-tabs-colors .collection__title.title-wrapper { margin-bottom: 2rem; }
  .collection-tabs-colors .collection_url { margin-top: 0.5rem; }

  .collection-tabs-colors .collection-tabs__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    justify-content: flex-start; /* = right in RTL */
  }

  .collection-tabs-colors .collection-tabs__tab {
    --swatch: #cccccc;
    position: relative;
    width: 40px;
    height: 40px;
    min-width: 2.4rem;
    padding: 0;
    border-radius: 50%;
    background-color: var(--swatch);
    background-size: cover;
    background-position: center;
    cursor: pointer;
    font-size: 0;
    line-height: 0;
    color: #fff;
  }

  .collection-tabs-colors .collection-tabs__check {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 58%;
    height: 58%;
    opacity: 0;
    transform: scale(0.4);
  }

  .collection-tabs-colors .collection-tabs__tab--active .collection-tabs__check {
    opacity: 1;
    transform: scale(1);
  }

  .collection-tabs-colors .visually-hidden {
    position: absolute !important;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  .collection-tabs-colors .collection-tabs__layout {
    display: grid;
    grid-template-columns: 34% 1fr; /* feature | slider */
    grid-template-areas: "feature main";
    gap: 2rem;
    align-items: center;
  }
  .collection-tabs-colors .collection-tabs__feature { grid-area: feature; height: 100%; }
  .collection-tabs-colors .collection-tabs__panels { grid-area: main; min-width: 0; }

  .collection-tabs-colors .collection-tabs__feature img,
  .collection-tabs-colors .collection-tabs__feature .placeholder-svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .collection-tabs-colors .collection-tabs__content--hidden { display: none; }
  .collection-tabs-colors .collection-tabs__content--active { display: block; }

  @media screen and (max-width: 989px) {
    .collection-tabs-colors .collection-tabs__layout {
      grid-template-columns: 1fr;
      grid-template-areas:
          "feature"
          "main";
      gap: 1.5rem;
    }
    .collection-tabs-colors .collection-tabs__feature img { max-height: 42rem; }
  }

  @media screen and (max-width: 749px) {
    .collection-tabs-colors .collection-tabs__tab {
      width: 3.2rem;
      height: 3.2rem;
      min-width: 2.2rem;
    }
  }
{%- endstyle -%}

{%- liquid
  assign per_page = section.settings.Preview | plus: 0
  assign max_columns_to_show = per_page
-%}

<div class="collection-tabs-colors collection-tabs--{{ section.id }} page-width wt-slider__container--featured section-{{ section.id }}-padding" dir="rtl">
  <div class="collection__title title-wrapper title-wrapper--no-top-margin page-width">
    {%- if section.settings.show_title -%}
      <h2
        style="text-align: {{ section.settings.text_alignment }};"
        {% if settings.enable_animations_on_scroll %}
          data-sal="fade-up" data-sal-duration="800" data-sal-delay="100" data-sal-easing="ease-out" data-sal-repeat="true"
        {% endif %}
        class="collection__title title"
      >
        {{ section.settings.title }}
      </h2>
    {%- endif -%}

    {%- if section.settings.show_description and section.settings.description != blank -%}
      <div
        class="collection__description  rte"
        style="text-align: {{ section.settings.text_alignment }};"
        {% if settings.enable_animations_on_scroll %}
          data-sal="fade-up" data-sal-duration="800" data-sal-delay="150" data-sal-easing="ease-out" data-sal-repeat="true"
        {% endif %}
      >
      <div class="description__content">
  {{ section.settings.description }}
</div>
      </div>
    {%- endif -%}

    {%- comment -%} ===================== TABS = color swatches ===================== {%- endcomment -%}
    {%- if section.settings.collection != blank -%}
      <div class="collection_url">
        <div class="collection-tabs__list" role="tablist">
          {%- for collection in section.settings.collection -%}
            {%- liquid
              assign swatch_image = blank
              
              # 1. محاولة جلب صورة الـ Collection نفسها أولاً
              if collection.image != blank
                assign swatch_image = collection.image
              else
                # 2. إذا لم تكن موجودة، جلب صورة أول منتج كبديل
                assign fp = collection.products.first
                if fp != blank and fp.featured_image != blank
                  assign swatch_image = fp.featured_image
                endif
              endif
            -%}
            <button
              class="collection-tabs__tab{% if forloop.first %} collection-tabs__tab--active{% endif %}"
              data-tab-target="CollectionTab-{{ section.id }}-{{ forloop.index }}"
              data-color="{{ collection.title | strip | downcase }}"
              aria-controls="CollectionTab-{{ section.id }}-{{ forloop.index }}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              role="tab"
              title="{{ collection.title | escape }}"
              {% if swatch_image != blank %}
                style="background-image: url({{ swatch_image | image_url: width: 120 }}); background-size: cover; background-position: center;"
              {% else %}
                style="--swatch: #cccccc;"
              {% endif %}
              {% if settings.enable_animations_on_scroll %}
                data-sal="slide-up" data-sal-duration="700" data-sal-delay="{{ forloop.index0 | times: 120 }}" data-sal-easing="ease-out" data-sal-repeat="true"
              {% endif %}
            >
              <span class="visually-hidden">{{ collection.title | default: 'Collection' }}</span>
              <svg class="collection-tabs__check" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M5 12.5l4.5 4.5L19 7.5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          {%- endfor -%}
        </div>
      </div>
    {%- else -%}
      <div class="collection_url">
        <div class="collection-tabs__list" role="tablist">
          <button class="collection-tabs__tab collection-tabs__tab--active" style="--swatch:#121212;"></button>
          <button class="collection-tabs__tab" style="--swatch:#6b7280;"></button>
          <button class="collection-tabs__tab" style="--swatch:#4d5d2f;"></button>
        </div>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ===================== LAYOUT: slider + big side image ===================== {%- endcomment -%}
  <div class="collection-tabs__contents page-width">
    <div class="collection-tabs__layout">
      <div class="collection-tabs__panels">
        {%- if section.settings.collection != blank -%}
          {%- for collection in section.settings.collection -%}
            
            <div
              id="CollectionTab-{{ section.id }}-{{ forloop.index }}"
              class="collection-tabs__content {% if forloop.first %}collection-tabs__content--active{% else %}collection-tabs__content--hidden{% endif %}"
              role="tabpanel"
              data-products-count="{{ products_to_display }}"
            >
              <slideshow-section class="wt-slider" data-skip-center-nav-method="true">
                <div data-swiper class="swiper wt-slider__container loading">
                  <div data-swiper-container class="swiper-wrapper wt-slider__wrapper">
                    {% assign skip_card_product_styles = false %}
                    {%- if collection.products.size > 0 -%}
                      {% assign lazy_load = false %}
                      
                        {%- for product in collection.products  -%}
                          {% if lazy_load == false and forloop.index > max_columns_to_show %}
                            {% assign lazy_load = true %}
                          {% endif %}
                          <div data-swiper-slide class="swiper-slide wt-slider__slide">
                            <div class="wt-slider__slide-inner">
                              {% assign image_hover = false %}
                              {% if settings.card_image_hover and product.images[1] %}
                                {% assign image_hover = product.images[1] %}
                              {% endif %}
                              {% render 'card',
                                card_product: product,
                                product: product,
                                img: product.featured_media,
                                img_hover: image_hover,
                                title: product.title,
                                subtitle: product.vendor,
                                url: product.url,
                                uri: product.handle,
                                variants: product.variants,
                                product_options: product.options,
                                reviews: product.metafields.reviews,
                                media_aspect_ratio: section.settings.image_ratio,
                                image_shape: section.settings.image_shape,
                                lazy_load: lazy_load,
                                show_secondary_image: settings.card_image_hover,
                                show_vendor: section.settings.show_vendor,
                                show_rating: section.settings.show_rating,
                                skip_styles: skip_card_product_styles,
                                section_id: section.id,
                                card_image_fit: settings.card_image_fit,
                                card_image_size: settings.card_image_size,
                                enable_quick_add_button: section.settings.enable_quick_add_button,
                                quick_add_mode: section.settings.quick_add_mode,
                                quick_add: settings.quick_add
                              %}
                            </div>
                          </div>
                          {%- assign skip_card_product_styles = true -%}
                        {%- endfor -%}
                      
                    {%- else -%}
                      {%- for i in (1..4) -%}
                        <div data-swiper-slide class="swiper-slide wt-slider__slide">
                          <div class="wt-slider__slide-inner">
                            {% liquid
                              assign ridx = forloop.rindex
                              case ridx
                                when 5
                                  assign ridx = 1
                                when 6
                                  assign ridx = 2
                              endcase
                            %}
                            {%- assign placeholder_image = 'product-apparel-' | append: ridx -%}
                            {% render 'card',
                              show_vendor: section.settings.show_vendor,
                              media_aspect_ratio: section.settings.image_ratio,
                              lazy_load: false,
                              placeholder_image: placeholder_image
                            %}
                          </div>
                        </div>
                      {%- endfor -%}
                    {%- endif -%}
                  </div>
                </div>
                <script data-swiper-configuration type="text/json">
                  {
                    "enableOnMedia": "(min-width: 0px)",
                    "slidesPerView": 1,
                    "spaceBetween": 8,
                    "freeMode": false,
                    "speed": 150,
                    "grabCursor": false,
                    "paginationType": "bullets",
                    "breakpoints": {
                      "480": { "slidesPerView": 1, "spaceBetween": 8 },
                      "768": { "slidesPerView": 2, "spaceBetween": 8 },
                      "990": { "slidesPerView": {{ per_page | default: 3 }}, "spaceBetween": 8 }
                    }
                  }
                </script>
              </slideshow-section>
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="collection-tabs__content collection-tabs__content--active" role="tabpanel">
            <slideshow-section class="wt-slider" data-skip-center-nav-method="true">
              <div data-swiper class="swiper wt-slider__container loading">
                <div data-swiper-container class="swiper-wrapper wt-slider__wrapper">
                  {%- for i in (1..4) -%}
                    <div data-swiper-slide class="swiper-slide wt-slider__slide">
                      <div class="wt-slider__slide-inner">
                        {%- assign placeholder_image = 'product-' | append: forloop.index -%}
                        {% render 'card',
                          media_aspect_ratio: section.settings.image_ratio,
                          lazy_load: false,
                          placeholder_image: placeholder_image
                        %}
                      </div>
                    </div>
                  {%- endfor -%}
                </div>

                <div class="swiper-button-next wt-slider__nav-btn wt-slider__nav-next wt-slider__nav-next--featured">
                  {% render 'icons', id: 'arrow-right' %}
                </div>
                <div class="swiper-button-prev wt-slider__nav-btn wt-slider__nav-prev wt-slider__nav-prev--featured">
                  {% render 'icons', id: 'arrow-left' %}
                </div>
              
              </div>
              <script data-swiper-configuration type="text/json">
                {
                  "enableOnMedia": "(min-width: 0px)",
                  "slidesPerView": 1,
                  "spaceBetween": 8,
                  "freeMode": false,
                  "speed": 150,
                  "grabCursor": false,
                  "paginationType": "bullets",
                  "breakpoints": {
                    "480": { "slidesPerView": 1, "spaceBetween": 8 },
                    "768": { "slidesPerView": 2, "spaceBetween": 8 },
                    "990": { "slidesPerView": {{ per_page | default: 3 }}, "spaceBetween": 8 }
                  }
                }
              </script>
            </slideshow-section>
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.feature_image != blank -%}
        <div class="collection-tabs__feature">
          {{
            section.settings.feature_image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              widths: '400, 600, 800, 1000, 1200',
              sizes: '(min-width: 990px) 34vw, 100vw',
              alt: section.settings.feature_image.alt
          }}
        </div>
      {%- else -%}
        <div class="collection-tabs__feature">
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  function initCollectionTabs_{{ section.id | replace: '-', '_' }}() {
    const container = document.querySelector('.collection-tabs--{{ section.id }}');
    if (!container) return;

    const tabs = container.querySelectorAll('.collection-tabs__tab');
    const contents = container.querySelectorAll('.collection-tabs__content');

    const normalizeColor = (value) =>
      String(value || '').trim().toLowerCase();

    const activateMatchingSwatch = (container, selectedColor) => {
      if (!selectedColor) return;

      const cards = container.querySelectorAll('color-swatch');
      cards.forEach((card) => {
        const tryClick = (attemptsLeft = 10) => {
          const swatches = Array.from(
            card.querySelectorAll('.color-swatcher[data-color]'),
          );

          const match = swatches.find((swatch) =>
            normalizeColor(swatch.dataset.color) === selectedColor,
          );

          if (match) {
            const wrapper = match.closest('.color-swatcher--wrapper');
            const target = wrapper || match;
            if (target && !target.classList.contains('active')) {
              target.click();
            }
          } else if (attemptsLeft > 0) {
            // color-swatch component may not be initialized yet; retry shortly
            setTimeout(() => tryClick(attemptsLeft - 1), 60);
          }
        };

        tryClick(10);
      });
    };

    const activateCurrentTabSwatches = (tab, targetContent) => {
      const selectedColor = normalizeColor(tab.dataset.color || tab.title);
      if (targetContent) activateMatchingSwatch(targetContent, selectedColor);
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const targetId = tab.getAttribute('data-tab-target');
        if (!targetId) return;

        tabs.forEach((t) => {
          t.classList.remove('collection-tabs__tab--active');
          t.setAttribute('aria-selected', 'false');
        });

        contents.forEach((c) => {
          c.classList.add('collection-tabs__content--hidden');
          c.classList.remove('collection-tabs__content--active');
        });

        tab.classList.add('collection-tabs__tab--active');
        tab.setAttribute('aria-selected', 'true');

        const targetContent = container.querySelector('#' + CSS.escape(targetId));
        if (targetContent) {
          targetContent.classList.remove('collection-tabs__content--hidden');
          targetContent.classList.add('collection-tabs__content--active');

          const swiperContainer = targetContent.querySelector('[data-swiper]');
          if (swiperContainer && swiperContainer.swiper) {
            swiperContainer.swiper.update();
          }

          activateCurrentTabSwatches(tab, targetContent);
        }
      });
    });

    const activeTab = container.querySelector('.collection-tabs__tab--active');
    const activeContent = container.querySelector('.collection-tabs__content--active');
    if (activeTab && activeContent) {
      activateCurrentTabSwatches(activeTab, activeContent);
    }

    // Update active swiper after resizing
    let resizeTimer;
    const handleResize = () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        contents.forEach((content) => {
          const swiperContainer = content.querySelector('[data-swiper]');
          if (swiperContainer && swiperContainer.swiper) {
            swiperContainer.swiper.update();
          }
        });
      }, 250);
    };

    window.removeEventListener('resize', handleResize);
    window.addEventListener('resize', handleResize);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCollectionTabs_{{ section.id | replace: '-', '_' }});
  } else {
    initCollectionTabs_{{ section.id | replace: '-', '_' }}();
  }

  document.addEventListener('shopify:section:load', function (event) {
    if (event.detail.sectionId === '{{ section.id }}') {
      initCollectionTabs_{{ section.id | replace: '-', '_' }}();
    }
  });
</script>

{% stylesheet %}
/* ===================== Product Categories (color tabs) ===================== */
/* Note: layout-critical rules (grid/flex/visibility) were moved to the inline
   {% style %} block above to prevent a flash of unstyled/overlapping content
   on first page load, before this external stylesheet finishes loading.
   This file keeps only cosmetic/enhancement rules. */

/* --- Header --- */
.collection-tabs-colors .collection__title.title { margin: 0 0 0.8rem;
font-size: 32px;
font-weight: 500;
color : var(--color-headings-text);
}
.collection-tabs-colors .collection__description { margin-bottom: 1.4rem;
font-size: 24px;
font-weight: 400; }
.collection-tabs-colors .collection__description > * { margin: 0; }
.collection-tabs-colors .description__highlight { font-weight: 700; }
.collection-tabs-colors .description__normal { opacity: 0.8; }

/* --- Tabs = color swatches (hover/transition polish) --- */
.collection-tabs-colors .collection-tabs__tab {
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.collection-tabs-colors .collection-tabs__tab:hover { transform: scale(1.08); }

.collection-tabs-colors .collection-tabs__check {
  transition: opacity 0.15s ease, transform 0.15s ease;
  filter: drop-shadow(0 0 1px rgba(0, 0, 0, 0.4));
}

/* --- Progress bar --- */
.collection-tabs-colors .my-slider-progress {
  width: 100%;
  height: 3px;
  margin-top: 1.4rem;
  background: rgba(18, 18, 18, 0.12);
  border-radius: 3px;
  overflow: hidden;
}
.collection-tabs-colors .my-slider-progress-bar {
  width: 0;
  height: 100%;
  background: #121212;
  border-radius: 3px;
  transition: width 0.3s ease;
}

/* --- View all --- */
.collection-tabs-colors .collection__view-all { margin-top: 1.4rem; }

/* ===================== Responsive (cosmetic) ===================== */
@media screen and (max-width: 749px) {
  /* To hide the big image on mobile, enable the line below: */
  /* .collection-tabs-colors .collection-tabs__feature { display: none; } */

  .collection-tabs-colors .collection__title.title {
    font-size: 18px;
    font-weight: 500;
  }
  .collection-tabs-colors .collection__description{
    font-size: 14px;
    font-weight: 400;
  }
}
.collection-tabs-colors .swiper-pagination .swiper-pagination-bullet--svg-animation {
  display: none !important;
}

{% endstylesheet %}

{% schema %}
{
  "name": "Product Categories",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection_list",
      "id": "collection",
      "limit": 6,
      "label": "Collections (one per color)"
    },
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Big side image"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show collection title",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "تسوقي الأطقم الكاملة",
      "label": "Heading",
      "visible_if": "{{ section.settings.show_title == true }}"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>اكتشفي أطقم سكراب واسعة وساترة، بتصاميم عملية وخامات مريحة تمنحك مظهرًا مهنيًا طوال ساعات الدوام.</p>",
      "visible_if": "{{ section.settings.show_description == true }}"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "select",
      "id": "Preview",
      "default": "3",
      "label": "Cards visible (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Card image ratio",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ],
      "default": "portrait"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add_button",
      "default": false,
      "label": "t:sections.featured-collection.settings.enable_quick_add_button.label",
      "info": "t:sections.featured-collection.settings.enable_quick_add_button.info"
    },
    {
      "type": "select",
      "id": "quick_add_mode",
      "label": "t:sections.featured-collection.settings.quick_add_layout.label",
      "options": [
        {
          "value": "hover_desktop",
          "label": "t:sections.featured-collection.settings.quick_add_layout.options.hover.label"
        },
        {
          "value": "below_product",
          "label": "t:sections.featured-collection.settings.quick_add_layout.options.below.label"
        }
      ],
      "default": "hover_desktop",
      "visible_if": "{{ section.settings.enable_quick_add_button }}"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Product Categories"
    }
  ]
}
{% endschema %}
