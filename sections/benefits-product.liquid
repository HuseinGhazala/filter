{% schema %}
{
  "name": "t:sections.benefits_product.name",
  "tag": "section",
  "class": "benefits-product-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.benefits_product.settings.important_information.content",
      "info": "t:sections.benefits_product.settings.important_information.info"
    },
   {
  "type": "header",
  "content": "Comparison Badges"
},
{
  "type": "text",
  "id": "left_badge_text",
  "label": "Left badge text (e.g. Regular Scrub)",
  "default": "Regular Scrub"
},
{
  "type": "color",
  "id": "left_badge_bg",
  "label": "Left badge background color",
  "default": "#cccccc"
},
{
  "type": "color",
  "id": "left_badge_color",
  "label": "Left badge text color",
  "default": "#333333"
},
{
  "type": "text",
  "id": "right_badge_text",
  "label": "Right badge text (e.g. Our Scrub)",
  "default": "Our Scrub"
},
{
  "type": "color",
  "id": "right_badge_bg",
  "label": "Right badge background color",
  "default": "#0d1b3e"
},
{
  "type": "color",
  "id": "right_badge_color",
  "label": "Right badge text color",
  "default": "#ffffff"
},
    {
      "type": "header",
      "content": "t:sections.global.general"
    },
    {
      "type": "checkbox",
      "id": "advanced_heading",
      "label": "t:sections.global.advanced_heading.label",
      "info": "t:sections.global.advanced_heading.info"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "t:sections.settings.settings.heading.label",
      "default": "Product Benefits",
      "visible_if": "{{ section.settings.advanced_heading == false }}"
    },
    {
      "type": "richtext",
      "id": "heading_richtext",
      "label": "t:sections.logo-banner.settings.content.headline.label",
      "default": "<h2>Product Benefits</h2>",
      "visible_if": "{{ section.settings.advanced_heading == true }}"
    },
    {
      "type": "checkbox",
      "id": "full-width-enabled",
      "label": "t:sections.settings.settings.section-full-width.label",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "t:sections.benefits_product.settings.mobile_image.label"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "t:sections.benefits_product.settings.desktop_image.label"
    },
    {
      "type": "video",
      "id": "video_hosted",
      "label": "t:sections.benefits_product.settings.video.label",
      "info": "t:sections.benefits_product.settings.video.info"
    },
    {
      "type": "select",
      "id": "section_height_mode",
      "info": "t:sections.benefits_product.settings.section_height_mode.info",
      "label": "t:sections.benefits_product.settings.section_height_mode.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "t:sections.benefits_product.settings.section_height_mode.options.auto.label"
        },
        {
          "value": "fixed_height",
          "label": "t:sections.benefits_product.settings.section_height_mode.options.fixed_height.label"
        }
      ]
    },
    {
      "type": "range",
      "id": "desktop_section_height",
      "min": 20,
      "max": 100,
      "unit": "%",
      "step": 1,
      "default": 60,
      "label": "t:sections.benefits_product.settings.desktop_section_height.label",
      "visible_if": "{{ section.settings.section_height_mode == 'fixed_height' }}"
    },
    {
      "type": "range",
      "id": "desktop_section_max_height",
      "min": 480,
      "max": 2000,
      "unit": "px",
      "step": 40,
      "default": 680,
      "label": "t:sections.benefits_product.settings.desktop_section_max_height.label",
      "visible_if": "{{ section.settings.section_height_mode == 'fixed_height' }}"
    },
    {
      "type": "range",
      "id": "desktop_width",
      "min": 20,
      "max": 100,
      "unit": "%",
      "step": 1,
      "default": 60,
      "label": "t:sections.benefits_product.settings.desktop_width.label",
