{% assign background_rgb = section.settings.background_color | color_to_rgb %}

<style>
  #section-{{ section.id }} {
    padding-top: {{ section.settings.margin_top }}px;
    padding-bottom: {{ section.settings.margin_bottom }}px;
    {% if section.settings.background_color != blank and section.settings.background_color != 'transparent' and background_rgb != 'rgba(0, 0, 0, 0.0)' %}
      background-color: {{ section.settings.background_color }};
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    #section-{{ section.id }} {
      padding-top: {{ section.settings.margin_top_mobile }}px;
      padding-bottom: {{ section.settings.margin_bottom_mobile }}px;
    }
  }

  .custom-features-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 24px;
    justify-content: center;
    align-items: flex-start;
  }

  .custom-feature-item {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
  }

  .custom-feature-image-wrapper {
    width: {{ section.settings.image_width_desktop }}px;
    height: {{ section.settings.image_height_desktop }}px;
    position: relative;
    border-radius: {{ section.settings.image_border_radius }}px;
    overflow: hidden;
    margin-bottom: 12px;
  }

  .custom-feature-image-wrapper img,
  .custom-feature-image-wrapper svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .custom-feature-title {
    font-size: {{ section.settings.title_font_size }}px;
    color: {{ section.settings.text_color }};
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }

  .custom-features-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .custom-features-main-title {
    font-size: 28px;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .custom-features-grid-{{ section.id }} {
      {% if section.settings.mobile_layout == 'slider' %}
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        padding-bottom: 10px;
        gap: 16px;
      {% else %}
        grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
        gap: 16px;
      {% endif %}
    }

    .custom-features-grid-{{ section.id }}::-webkit-scrollbar {
      display: none;
    }

    .custom-feature-item {
      {% if section.settings.mobile_layout == 'slider' %}
        flex: 0 0 calc(100% / {{ section.settings.columns_mobile }} - 12px);
        scroll-snap-align: center;
      {% endif %}
    }

    .custom-feature-image-wrapper {
      width: {{ section.settings.image_width_mobile }}px;
      height: {{ section.settings.image_height_mobile }}px;
    }

    .custom-feature-title {
      font-size: {{ section.settings.title_font_size_mobile }}px;
    }
  }
</style>

<div id="section-{{ section.id }}" class="custom-features-banner page-width wt-slider__container--featured">
  {% if section.settings.heading != blank %}
    <div class="custom-features-header">
      <h2 class="custom-features-main-title">{{ section.settings.heading | escape }}</h2>
    </div>
  {% endif %}

  <div class="custom-features-grid-{{ section.id }}">
    {% for block in section.blocks %}
      <{% if block.settings.link != blank %}a href="{{ block.settings.link }}"{% else %}div{% endif %} 
        class="custom-feature-item" 
        {{ block.shopify_attributes }}>
        
        <div class="custom-feature-image-wrapper">
          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | img_url: '400x400' }}"
              alt="{{ block.settings.title | escape }}"
              loading="lazy"
              width="200"
              height="200"
            >
                
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>

        {% if block.settings.title != blank %}
          <h3 class="custom-feature-title">{{ block.settings.title }}</h3>
        {% endif %}

      </{% if block.settings.link != blank %}a{% else %}div{% endif %}>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Store Features",
  "tag": "section",
  "class": "wt-shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading (Optional)"
    },
    {
      "type": "header",
      "content": "Desktop Settings"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Columns on Desktop"
    },
    {
      "type": "range",
      "id": "image_width_desktop",
      "min": 40,
      "max": 250,
      "step": 5,
      "unit": "px",
      "default": 120,
      "label": "Image Width (Desktop)"
    },
    {
      "type": "range",
      "id": "image_height_desktop",
      "min": 40,
      "max": 250,
      "step": 5,
      "unit": "px",
      "default": 120,
      "label": "Image Height (Desktop)"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18,
      "label": "Title Font Size (Desktop)"
    },
    {
      "type": "header",
      "content": "Mobile Settings"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "options": [
        { "value": "grid", "label": "Grid Layout" },
        { "value": "slider", "label": "Horizontal Scroll" }
      ],
      "default": "grid",
      "label": "Mobile Layout Style"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2,
      "label": "Columns / Visible items on Mobile"
    },
    {
      "type": "range",
      "id": "image_width_mobile",
      "min": 30,
      "max": 180,
      "step": 5,
      "unit": "px",
      "default": 90,
      "label": "Image Width (Mobile)"
    },
    {
      "type": "range",
      "id": "image_height_mobile",
      "min": 30,
      "max": 180,
      "step": 5,
      "unit": "px",
      "default": 90,
      "label": "Image Height (Mobile)"
    },
    {
      "type": "range",
      "id": "title_font_size_mobile",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 15,
      "label": "Title Font Size (Mobile)"
    },
    {
      "type": "header",
      "content": "Design & Colors"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 50,
      "label": "Image Border Radius (Use 50+ for Circle)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 20,
      "unit": "px",
      "label": "Top Padding (Desktop)"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 20,
      "unit": "px",
      "label": "Bottom Padding (Desktop)"
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 16,
      "unit": "px",
      "label": "Top Padding (Mobile)"
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 16,
      "unit": "px",
      "label": "Bottom Padding (Mobile)"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Feature Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "راحة فائقة"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Features",
      "blocks": [
        {
          "type": "feature",
          "settings": { "title": "صناعة سعودية" }
        },
        {
          "type": "feature",
          "settings": { "title": "مقاوم للتجعد" }
        },
        {
          "type": "feature",
          "settings": { "title": "واسع و فضفاض" }
        },
        {
          "type": "feature",
          "settings": { "title": "راحة فائقة" }
        }
      ]
    }
  ]
}
{% endschema %}