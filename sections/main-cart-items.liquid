<style>
  [data-section-id="{{ section.id }}"] {
    {% if section.settings.margin-top %}
      --section-gap-top: {{ section.settings.margin-top }}px;
    {% endif %}

    {% if section.settings.margin-bottom %}
      --section-gap-bottom: {{ section.settings.margin-bottom }}px;
    {% endif %}

    {%- if section.settings.show_mobile_spacing -%}
      --section-gap-top-mobile: {{ section.settings.margin-top-mobile }}px;
    {%- endif -%}

    {%- if section.settings.show_mobile_spacing -%}
      --section-gap-bottom-mobile: {{ section.settings.margin-bottom-mobile }}px;
    {%- endif -%}
  }
</style>

<div data-section-id="{{ section.id }}">
  <cart-items class="cart-page">
    <form action="{{ routes.cart_url }}" class="cart__contents critical-hidden" method="post" id="cart">
      <div class="wt-cart__wrapper cart-page" id="main-cart-items" data-id="{{ section.id }}">
        
        <div class="wt-cart js-contents">
          <!-- الهيدر الخاص بالسلة -->
          <header class="wt-cart__header {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
            {%- if cart != empty -%}
              <div class="wt-cart__header__action">
                <h2 class="wt-cart__title">
                  {{ 'sections.cart.title' | t }}
                  {% if cart.item_count > 0 %}
                    ({{ cart.item_count }})
                  {% endif %}
                </h2>
              </div>

              {%- if settings.enable_free_shipping_bar or settings.enable_discount_progress_bar -%}
                <div class="wt-cart__header__progress">
                  {% if settings.enable_free_shipping_bar %}
                    {% render 'cart-free-shipping-bar' %}
                  {% endif %}

                  {% if settings.enable_discount_progress_bar %}
                    {% render 'discount-progress-bar' %}
                  {% endif %}
                </div>
              {%- endif -%}

            {%- else -%}
              {% render 'cart-empty' %}
            {%- endif -%}
          </header>
          <div class="wt-cart__body-wrapper">

            
          <!-- قائمة المنتجات -->
          {%- if cart != empty -%}
            <div class="wt-cart__body {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
              <ul class="wt-cart__list">
                {%- for item in cart.items -%}
                  {% render 'cart-item', item: item, cart_page: true, show_vendor: section.settings.show_vendor %}
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
               {%- if cart != empty -%}
          <div class="wt-cart__footer-container" id="main-cart-footer" data-id="{{ section.id }}">
                   {% render 'free-shipping-bar',
            enable: true,
            amount: "USD:1000",
            text: settings.free_shipping_bar_text,
            text_success: settings.free_shipping_bar_text_success
        %}
            <div class="wt-cart__footer">

              {% render 'cart-additional-features', context: 'page' %}

              <div class="wt-cart__subtitle">
                {%- if settings.cart_show_additional_service -%}
                  {%- render 'cart-checkbox' -%}
                {%- endif -%}
              </div>

              <div class="wt-cart__subtitle__tax">
                {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
                  {{ 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url, tabindex: 0 }}
                {%- elsif cart.taxes_included -%}
                  {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t }}
                {%- elsif shop.shipping_policy.body != blank -%}
                  {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url, tabindex: 0 }}
                {%- else -%}
                  {{ 'sections.cart.taxes_and_shipping_at_checkout' | t }}
                {%- endif -%}
              </div>

              <div class="wt-cart__footer__body">
                {% for block in section.blocks %}
                  {%- case block.type -%}
                    {%- when '@app' -%}
                      {% render block %}
                    {%- when 'custom_liquid' -%}
                      {{ block.settings.custom_liquid }}
                    {%- when 'subtotal' -%}
                      <div class="js-contentss">
                        <div class="wt-cart__subtotal" {{ block.shopify_attributes }}>
                          <div class="wt-cart__subtotal__label">
                            <span class="text">{{ 'sections.cart.subtotal' | t }}</span>
                          </div>
                          <div class="wt-cart__subtotal__value">
                            {{ cart.total_price | money_with_currency }}
                          </div>
                          {%- if settings.cart_show_savings and cart.total_discount > 0 -%}
                            {%- assign savings_formatted = cart.total_discount | money -%}
                            {%- assign savings_label = settings.cart_savings_label | replace: '||savings||', savings_formatted -%}
                            <div class="wt-cart__savings">
                              <span class="wt-cart__savings__label">{{ savings_label }}</span>
                              <span class="wt-cart__savings__original">{{ cart.original_total_price | money }}</span>
                            </div>
                          {%- endif -%}
                        </div>
                        {%- if cart.cart_level_discount_applications.size > 0 -%}
                          <div>
                            <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                              {%- for discount in cart.cart_level_discount_applications -%}
                                <li class="discounts__discount discounts__discount--position">
                                  {%- render 'icon-discount' -%}
                                  {{ discount.title }}
                                  (-{{ discount.total_allocated_amount | money }})
                                </li>
                              {%- endfor -%}
                            </ul>
                          </div>
                        {%- endif -%}
                      </div>
                    {%- when 'buttons' -%}
                      <div class="wt-cart__actions" {{ block.shopify_attributes }}>
                        <noscript>
                          <button aria-label="{{ 'sections.cart.update' | t }}" type="submit" class="cart__update-button button button--secondary" form="cart">
                            {{ 'sections.cart.update' | t }}
                          </button>
                        </noscript>

                        <button aria-label="{{ 'sections.cart.checkout' | t }}" type="submit" class="wt-cart__cta cart__checkout" name="checkout" {% if cart == empty %} disabled {% endif %} form="cart">
                          {% comment %} {% if settings.enable-lock-icon %}
                            {% render 'icon-lock' %}
                          {% endif %} {% endcomment %}

                            {{ 'templates.cart.btn_cart' | t: terms: search.terms }}
                            <span>
                              {{ cart.total_price | money_with_currency }}
                          </span>
  
                          {% comment %} {{ 'sections.cart.checkout' | t }} {% endcomment %}
                        </button>

                        <a href="{{ routes.all_products_collection_url }}" class="wt-button wt-button--secondary wt-button--full-width wt-cart__back-link">
                          {{ 'general.continue_shopping' | t }}
                        </a>
                      </div>

                      {%- if additional_checkout_buttons -%}
                        <div class="cart__dynamic-checkout-buttons additional-checkout-buttons">
                          {{ content_for_additional_checkout_buttons }}
                        </div>
                      {%- endif -%} 


                  {%- endcase -%}
                {% endfor %}

                {%- assign trust_badges = section.blocks | where: "type", "trust_badge" -%}
                {%- if trust_badges.size > 0 -%}
                  <div class="cart-trust-badges" style="display: flex; justify-content: space-around; gap: 15px; margin: 20px 0; flex-wrap: wrap; text-align: center;">
                    {%- for block in trust_badges -%}
                      <div class="trust-badge-item" style="flex: 1; min-width: 120px; max-width: 200px;" {{ block.shopify_attributes }}>
                        {%- if block.settings.image != blank -%}
                          <div class="trust-badge-image" style="margin-bottom: 10px; ">
                            <img src="{{ block.settings.image | image_url: width: 150 }}" alt="{{ block.settings.title }}" style="max-width: 80px; height: 60px; object-fit: contain;" loading="lazy">
                          </div>
                        {%- endif -%}
                        {%- if block.settings.title != blank -%}
                          <h4 style="margin: 0 0 5px 0; font-size: 16px; font-weight: bold; color: var(--color-text);">{{ block.settings.title }}</h4>
                        {%- endif -%}
                        {%- if block.settings.subtext != blank -%}
                          <p style="margin: 0; font-size: 13px; color: var(--color-text); opacity: 0.8;">{{ block.settings.subtext }}</p>
                        {%- endif -%}
                      </div>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
    {% comment %} {%- if section.settings.enable_loyalty_points -%}
  <div class="wt-cart__loyalty">
    <div class="wt-cart__loyalty__row">
      <span class="wt-cart__loyalty__label">
        <i class="ti ti-award"></i> نقاط الولاء
      </span>
      {%- if customer -%}
        {%- assign earned_points = cart.total_price | divide: 100.0 | times: section.settings.points_per_currency_unit | round -%}
        <span class="wt-cart__loyalty__points">+ {{ earned_points }} points</span>
      {%- endif -%}
    </div>
    {%- unless customer -%}
      <a href="{{ routes.account_login_url }}" class="wt-cart__loyalty__link">
        يرجى تسجيل الدخول لعرض نقاطك والاستفادة منها ←
      </a>
    {%- endunless -%}
  </div>
{%- endif -%} {% endcomment %}

                {%- render 'cart-payment-badge' -%} 
                <div id="cart-errors"></div>
              </div>
            </div>
          </div>
        {%- endif -%}
        </div>

   
     </div>

      </div>
      <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
      <p class="visually-hidden" id="shopping-cart-line-item-status" aria-live="polite" aria-hidden="true" role="status">
        {{ 'accessibility.loading' | t }}
      </p>
    </form>
  </cart-items>
</div>

<style>
  .wt-cart__cta.cart__checkout{
    font-family: 'Merriweather';
    text-transform: capitalize;
    font-size: 12px;
    font-weight: 600;
  }
  .wt-cart__cta.cart__checkout span{
    font-weight: 400;
    font-size:11px
    margin-top: 4px;
  }



  
</style>
{% schema %}
{
  "name": "Main Cart",
  "tag": "section",
  "class": "cart__footer-wrapper",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "t:sections.main-cart-items.settings.show_vendor.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.section_spacing"
    },
    {
      "type": "range",
      "id": "margin-top",
      "min": 0,
      "max": 100,
      "unit": "px",
      "step": 4,
      "default": 40,
      "label": "t:sections.settings.settings.distance-top.label"
    },
    {
      "type": "range",
      "id": "margin-bottom",
      "min": 0,
      "max": 100,
      "unit": "px",
      "step": 4,
      "default": 0,
      "label": "t:sections.settings.settings.distance-bottom.label"
    },
    {
      "type": "checkbox",
      "id": "show_mobile_spacing",
      "label": "t:sections.settings.settings.show-mobile-spacing.label"
    },
    {
      "type": "range",
      "id": "margin-top-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-top-mobile.label"
    },
    {
      "type": "range",
      "id": "margin-bottom-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-bottom-mobile.label"
    }
  ],
"blocks": [
    {
      "type": "@app"
    },
    {
      "type": "custom_liquid",
      "name": "Custom Liquid",
      "settings": [
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "Custom Liquid Code"
        }
      ]
    },
    {
      "type": "subtotal",
      "name": "Subtotal",
      "limit": 1
    },
    {
      "type": "buttons",
      "name": "Checkout Buttons",
      "limit": 1
    },
    {
      "type": "trust_badge",
      "name": " featured Collection",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": " choose image",
        },
        {
          "type": "text",
          "id": "title",
          "label": "Main Title",
          "default": "شحن مجاني "
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "  Sub Text",
          "default": "لكل طلب فوق 450 ريال"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}