{{ 'section-multicol.css' | asset_url | stylesheet_tag }}
{{ 'section-video.css' | asset_url | stylesheet_tag }}
{{ 'swiper.css' | asset_url | stylesheet_tag }}

{% assign background_rgb = section.settings.background_color | color_to_rgb %}
{% assign text_rgb = section.settings['color-body-text'] | color_to_rgb %}


<style>
  [data-section-id="{{ section.id }}"] {

      {% if section.settings.margin-top %}
          --section-gap-top: {{ section.settings.margin-top }}px;
      {% endif %}

      {% if section.settings.margin-bottom %}
          --section-gap-bottom: {{ section.settings.margin-bottom }}px;
      {% endif %}

      {%- if section.settings.show_mobile_spacing -%}
          --section-gap-top-mobile: {{ section.settings.margin-top-mobile }}px;
      {%- endif -%}

      {%- if section.settings.show_mobile_spacing -%}
          --section-gap-bottom-mobile: {{ section.settings.margin-bottom-mobile }}px;
      {%- endif -%}

      {% if section.settings.full-width-enabled %}
          --border-radius: 0;
      {% endif %}

      {% if section.settings['background_color'] != blank and section.settings['background_color'] != 'transparent' and background_rgb != 'rgba(0, 0, 0, 0.0)' %}
        --color-background: {{ section.settings.background_color }};
      {% endif %}

      {% if section.settings['color-body-text'] != blank and section.settings['color-body-text'] != 'transparent' and text_rgb != 'rgba(0, 0, 0, 0.0)' %}
        --color-custom-text: {{ section.settings.color-body-text }};
      {% endif %}

      {% if section.settings.image_ratio == 'square' %}
        --aspect-ratio: 1/1;
      {% elsif section.settings.image_ratio == 'portrait' %}
        --aspect-ratio: var(--aspect-ratio-portait);
      {% endif %}

      {% unless section.settings['full-width-enabled'] %}
        --grid-gap: {{ section.settings.spacing_desktop }}px;
        --grid-gap-mobile: {{ section.settings.spacing_mobile }}px;
      {% endunless %}
  }

  [data-section-id="{{ section.id }}"] .headline__title
  {
    {% if section.settings['color-body-text'] != blank and section.settings['color-body-text'] != 'transparent' and text_rgb != 'rgba(0, 0, 0, 0.0)' %}
      --color-custom-text: {{ section.settings.color-body-text }};
    {% endif %}
  }

  {%- for block in section.blocks -%}
    {% assign background_rgb = block.settings.color-overlay  | color_to_rgb %}
    {% assign text_rgb = block.settings['color-body-text'] | color_to_rgb %}

      [data-block-id="{{ block.id }}"] {
        {% if block.settings['color-overlay'] != blank and block.settings['color-overlay'] != 'transparent' and background_rgb != 'rgba(0, 0, 0, 0.0)' %}
          --color-overlay-rgb: {{ block.settings.color-overlay | color_to_rgb | remove: 'rgb(' | remove: ')' }};
          --color-overlay-opacity: {{ block.settings.color-overlay-opacity | divided_by: 100.0 }};
          {% endif %}
          {% if block.settings['color-body-text'] != blank and block.settings['color-body-text'] != 'transparent' and text_rgb != 'rgba(0, 0, 0, 0.0)' %}
            --color-custom-text: {{ block.settings.color-body-text }};
          {% endif %}

          --font-headline-scale-desk: {{ block.settings.size_heading | divided_by: 100.0 }};

          --font-headline-scale: {{ block.settings.size_heading_mobile | divided_by: 100.0 }};

          {% if section.settings.image_ratio == 'adapt' and block.settings.desktop_image %}
            --aspect-ratio: {{ block.settings.desktop_image.aspect_ratio }};
          {% endif %}
          {% if section.settings.image_ratio == 'adapt' and block.settings.mobile_image %}
            --img-mobile-ratio: {{ block.settings.mobile_image.aspect_ratio }};
          {% endif %}

          {% if block.type == 'image' and block.settings.subheading_advanced_settings %}
            --font-subheading-scale: {{ block.settings.size_text_mobile | divided_by: 100.0 }};
            --font-subheading-scale-desk: {{ block.settings.size_text_desktop | divided_by: 100.0 }};
            --subheading-letter-spacing: {{ block.settings.letter_spacing }}px;
            {% if block.settings.text_uppercase %}
              --subheading-text-transform: uppercase;
            {% endif %}
            {% if block.settings.subheading_text_style == 'body' %}
              --subheading-font-family: var(--font-base);
            {% endif %}
          {% endif %}
      }
  {%- endfor -%}
</style>

<div
  class="wt-grid-box {% if settings.animations and section.settings['full-width-enabled'] != true %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %} {% if section.settings.image_ratio == 'adapt' %}wt-grid-box--adapt {% endif %}"
  data-section-id="{{ section.id }}"
>
  {% if section.settings.advanced_heading %}
    {% if section.settings.heading_richtext != blank %}
        <div class="headline headline--rich {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
            {{ section.settings.heading_richtext }}
        </div>
    {% endif %}
  {% else %}
    {% if section.settings.title != blank %}
        {% render 'headline', title: section.settings.title %}
    {% endif %}
  {% endif %}

  {% if section.settings.swipe_on_mobile %}
    <script type="module" src="{{ 'slider.js' | asset_url }}" defer="defer"></script>
    <slideshow-section class="wt-slider">
  {% endif %}
  <div
    data-swiper
    class="wt-grid-box__container {% if section.settings.full-width-enabled %} wt-grid-box__container--full {% endif %}"
  >
    {% assign i = 0 %}
    <ul
      data-swiper-container
      class="wt-grid-box__ul {% if section.settings.swipe_on_mobile %}wt-grid-box__ul--swipe{% endif %}"
    >
      {%- for block in section.blocks -%}
        {% assign i = i | plus: 1 %}
        <li class="wt-grid-box__li" data-swiper-slide>
          <div
            data-block-id="{{ block.id }}"
            {% if settings.animations %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
            class="wt-grid-box__item {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
          >
              {% render 'hero',
              type: 'single',
              desktop_text_horizontal_position: block.settings.desktop_text_horizontal_position,
              desktop_text_vertical_position: block.settings.desktop_text_vertical_position,
              mobile_text_horizontal_position: block.settings.mobile_text_horizontal_position,
              mobile_text_vertical_position: block.settings.mobile_text_vertical_position,
              desktop_image: block.settings.desktop_image,
              mobile_image: block.settings.mobile_image,
              video: block.settings.video_hosted,
              mobile_video: block.settings.video_hosted_mobile,
              show_bottom: block.settings.show_bottom,
              subheading: block.settings.subheading,
              subheading_bottom: block.settings.subheading_bottom,
              logo: block.settings.logo,
              subheading_disable_on_mobile: block.settings.subheading_disable_on_mobile,
              heading: block.settings.heading,
              text: block.settings.text,
              button_label: block.settings.button_label,
              button_link: block.settings.button_link,
              button_link_in_new_window: block.settings.button_link_in_new_window,
              heading_disable_on_mobile: block.settings.heading_disable_on_mobile,
              text_disable_on_mobile: block.settings.text_disable_on_mobile,
              button_disable_on_mobile: block.settings.button_disable_on_mobile,
              button_select: block.settings.button_select,
              placeholder: 'collection-apparel-1',
              section_link: block.settings.button_link
            %}
          </div>
        </li>
      {%- endfor -%}
    </ul>

    {% if section.settings['full-width-enabled'] %}
      {% assign slidesPerView = 1 %}
    {% else %}
      {% assign slidesPerView = 1.04 %}
    {% endif %}

    {% if section.settings.swipe_on_mobile %}
      <div class="swiper-button-next wt-slider__nav-btn wt-slider__nav-next wt-slider__nav-next--featured">
        {% render 'icons', id: 'arrow-right' %}
      </div>
      <div class="swiper-button-prev wt-slider__nav-btn wt-slider__nav-prev wt-slider__nav-prev--featured">
        {% render 'icons', id: 'arrow-left' %}
      </div>
      <div class="swiper-pagination wt-slider__pagination"></div>

      <script data-swiper-configuration type="text/json">
        {
        "enableOnMedia": "(max-width: 899px)",
        "freeMode": false,
        "speed": 150,
        "grabCursor": false,
        "paginationType": "bullets",
        "slidesPerView": {{ slidesPerView }},
        "slidesPerGroup": 1,
        "spaceBetween": {% if section.settings['full-width-enabled'] %}0{% else %}{{ section.settings.spacing_mobile }}{% endif %},
        "navigation": {
            "nextEl": ".wt-slider__nav-next--featured",
            "prevEl": ".wt-slider__nav-prev--featured"
        }
        }
      </script>
    {% endif %}
  </div>
  {% if section.settings.swipe_on_mobile %}
    </slideshow-section>
  {% endif %}
</div>

{% schema %}
{
  "name": "t:sections.grid-view.name",
  "class": "wt-shopify-section",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "advanced_heading",
      "label": "t:sections.global.advanced_heading.label",
      "info": "t:sections.global.advanced_heading.info"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "t:sections.settings.settings.heading.label",
      "default": "Grid view",
      "visible_if": "{{ section.settings.advanced_heading == false }}"
    },
    {
      "type": "richtext",
      "id": "heading_richtext",
      "label": "t:sections.logo-banner.settings.content.headline.label",
      "default": "<h2>Grid view</h2>",
      "visible_if": "{{ section.settings.advanced_heading == true }}"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "t:sections.multicolumn.settings.swipe_on_mobile.label"
    },
    {
      "type": "checkbox",
      "id": "full-width-enabled",
      "label": "t:sections.settings.settings.section-full-width.label",
      "default": false
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.multicolumn.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.multicolumn.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.multicolumn.settings.image_ratio.options__3.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.multicolumn.settings.image_ratio.label"
    },
    {
      "type": "select",
      "id": "spacing_desktop",
      "options": [
        {
          "value": "8",
          "label": "t:sections.main-collection-product-grid.settings.spacing_desktop.1.label"
        },
        {
          "value": "16",
          "label": "t:sections.main-collection-product-grid.settings.spacing_desktop.2.label"
        },
        {
          "value": "24",
          "label": "t:sections.main-collection-product-grid.settings.spacing_desktop.3.label"
        }
      ],
      "default": "24",
      "label": "t:sections.grid-view.settings.spacing_desktop.label",
      "visible_if": "{{ section.settings['full-width-enabled'] == false }}"
    },
    {
      "type": "select",
      "id": "spacing_mobile",
      "options": [
        {
          "value": "4",
          "label": "4px"
        },
        {
          "value": "8",
          "label": "8px"
        },
        {
          "value": "12",
          "label": "12px"
        },
        {
          "value": "16",
          "label": "16px"
        }
      ],
      "default": "16",
      "label": "t:sections.grid-view.settings.spacing_mobile.label",
      "visible_if": "{{ section.settings['full-width-enabled'] == false }}"
    },
    {
      "type": "header",
      "content": "t:sections.global.colors",
      "info": "t:sections.global.colors-info"
    },
    {
      "type": "color",
      "id": "color-body-text",
      "label": "t:sections.settings.settings.text-color.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.settings.settings.background-color.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.section_spacing"
    },
    {
      "type": "range",
      "id": "margin-top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-top.label"
    },
    {
      "type": "range",
      "id": "margin-bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-bottom.label",
      "info": "t:sections.settings.settings.distance-bottom.info"
    },
    {
      "type": "checkbox",
      "id": "show_mobile_spacing",
      "label": "t:sections.settings.settings.show-mobile-spacing.label"
    },
    {
      "type": "range",
      "id": "margin-top-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-top-mobile.label",
      "visible_if": "{{ section.settings.show_mobile_spacing }}"
    },
    {
      "type": "range",
      "id": "margin-bottom-mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-bottom-mobile.label",
      "visible_if": "{{ section.settings.show_mobile_spacing }}"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.grid-view.settings.image.name",
      "settings": [
        {
          "type": "header",
          "content": "t:sections.global.general"
        },
        {
          "type": "checkbox",
          "id": "show_bottom",
          "label": "Show Bottom Content",
          "default": false
        },
        {
          "type": "text",
          "id": "subheading_bottom",
          "label": "Bottom Text",
          "visible_if": "{{ block.settings.show_bottom }}"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Bottom Logo",
          "visible_if": "{{ block.settings.show_bottom }}"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "t:sections.settings.settings.subheading.label",
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {
          "type": "checkbox",
          "id": "subheading_disable_on_mobile",
          "label": "t:sections.global.disable_on_mobile",
          "default": false,
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {  
          "type": "checkbox",
          "id": "subheading_advanced_settings",
          "label": "t:sections.global.subheading_advanced_settings",
          "info": "t:sections.global.subheading_advanced_settings_info",
          "default": false,
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {
          "type": "select",
          "id": "subheading_text_style",
          "options": [
            {
              "value": "subtitle",
              "label": "t:sections.global.text_style_subtitle"
            },
            {
              "value": "body",
              "label": "t:sections.global.text_style_body"
            }
          ],
          "default": "subtitle",
          "label": "t:sections.global.text_style_name",
          "visible_if": "{{ block.settings.subheading_advanced_settings and block.settings.show_bottom == false }}"
        },
        {
          "type": "checkbox",
          "id": "text_uppercase",
          "label": "t:sections.settings.settings.text_uppercase.label",
          "default": false,
          "visible_if": "{{ block.settings.subheading_advanced_settings and block.settings.show_bottom == false }}"
        },
        {
          "type": "range",
          "id": "letter_spacing",
          "min": 0,
          "max": 3,
          "step": 0.1,
          "default": 1,
          "unit": "px",
          "label": "t:sections.settings.settings.letter_spacing.label",
          "visible_if": "{{ block.settings.subheading_advanced_settings and block.settings.show_bottom == false }}"
        },
        {
          "type": "range",
          "id": "size_text_desktop",
          "min": 50,
          "max": 300,
          "step": 10,
          "default": 100,
          "unit": "%",
          "label": "t:sections.settings.settings.size-text.label",
          "visible_if": "{{ block.settings.subheading_advanced_settings and block.settings.show_bottom == false }}"
        },
        {
          "type": "range",
          "id": "size_text_mobile",
          "min": 50,
          "max": 300,
          "step": 10,
          "default": 100,
          "unit": "%",
          "label": "t:sections.settings.settings.size-text-mobile.label",
          "visible_if": "{{ block.settings.subheading_advanced_settings and block.settings.show_bottom == false }}"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Column",
          "label": "t:sections.settings.settings.heading.label",
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {
          "type": "checkbox",
          "id": "heading_disable_on_mobile",
          "label": "t:sections.global.heading_disable_on_mobile",
          "default": false,
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {
          "type": "range",
          "id": "size_heading",
          "min": 50,
          "max": 300,
          "step": 10,
          "default": 100,
          "label": "t:sections.settings.settings.size-heading.label",
          "unit": "%",
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {
          "type": "range",
          "id": "size_heading_mobile",
          "min": 80,
          "max": 300,
          "step": 10,
          "default": 100,
          "label": "t:sections.settings.settings.size-heading-mobile.label",
          "unit": "%",
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {
          "type": "text",
          "id": "text",
          "default": "Give customers details about the image or content on the template.",
          "label": "t:sections.settings.settings.text.label",
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {
          "type": "checkbox",
          "id": "text_disable_on_mobile",
          "label": "t:sections.global.disable_on_mobile",
          "default": false,
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {
          "type": "header",
          "content": "t:sections.image-banner.button.name",
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {
          "type": "select",
          "id": "button_select",
          "options": [
            {
              "value": "primary",
              "label": "t:sections.settings.settings.button_select.primary.label"
            },
            {
              "value": "secondary",
              "label": "t:sections.settings.settings.button_select.secondary.label"
            },
            {
              "value": "link",
              "label": "t:sections.settings.settings.button_select.link.label"
            }
          ],
          "default": "primary",
          "label": "t:sections.settings.settings.button_select.default.label",
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {
          "id": "button_label",
          "type": "text",
          "default": "Button label",
          "label": "t:sections.settings.settings.button_label.label",
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {
          "type": "checkbox",
          "id": "button_disable_on_mobile",
          "label": "t:sections.global.disable_on_mobile",
          "default": false,
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:sections.settings.settings.link.label",
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {
          "type": "checkbox",
          "id": "button_link_in_new_window",
          "label": "t:sections.global.button_link_in_new_window",
          "default": false
        },
        {
          "type": "header",
          "content": "t:sections.global.colors",
          "info": "t:sections.global.block-colors-info"
        },
        {
          "type": "color",
          "id": "color-body-text",
          "label": "t:sections.settings.settings.text-color.label"
        },
        {
          "type": "color",
          "id": "color-overlay",
          "label": "t:sections.settings.settings.background-color.label"
        },
        {
          "type": "range",
          "id": "color-overlay-opacity",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 0,
          "label": "t:sections.settings.settings.background-opacity.label"
        },
        {
          "type": "header",
          "content": "t:sections.global.desktop_version"
        },
        {
          "type": "video",
          "id": "video_hosted",
          "label": "t:sections.logo-banner.settings.video-hosted.label"
        },
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "t:sections.settings.settings.image.label"
        },
        {
          "type": "select",
          "id": "desktop_text_vertical_position",
          "options": [
            {
              "value": "top",
              "label": "t:sections.grid-view.settings.image.desktop_text_vertical_position.top.label"
            },
            {
              "value": "center",
              "label": "t:sections.grid-view.settings.image.desktop_text_vertical_position.center.label"
            },
            {
              "value": "bottom",
              "label": "t:sections.grid-view.settings.image.desktop_text_vertical_position.bottom.label"
            }
          ],
          "default": "center",
          "label": "t:sections.grid-view.settings.image.desktop_text_vertical_position.default.label",
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {
          "type": "select",
          "id": "desktop_text_horizontal_position",
          "options": [
            {
              "value": "left",
              "label": "t:sections.grid-view.settings.image.desktop_text_horizontal_position.left.label"
            },
            {
              "value": "center",
              "label": "t:sections.grid-view.settings.image.desktop_text_horizontal_position.center.label"
            },
            {
              "value": "right",
              "label": "t:sections.grid-view.settings.image.desktop_text_horizontal_position.right.label"
            }
          ],
          "default": "center",
          "label": "t:sections.grid-view.settings.image.desktop_text_horizontal_position.default.label",
          "visible_if": "{{ block.settings.show_bottom == false }}"
        },
        {
          "type": "header",
          "content": "t:sections.global.mobile_version"
        },
        {
          "type": "video",
          "id": "video_hosted_mobile",
          "label": "t:sections.logo-banner.settings.video-hosted.label"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "t:sections.settings.settings.image.label"
        },
        {
          "type": "select",
          "id": "mobile_text_vertical_position",
          "options": [
            {
              "value": "top",
              "label": "t:sections.grid-view.settings.image.mobile_text_vertical_position.top.label"
            },
            {
              "value": "center",
              "label": "t:sections.grid-view.settings.image.mobile_text_vertical_position.center.label"
            },
            {
              "value": "bottom",
              "label": "t:sections.grid-view.settings.image.mobile_text_vertical_position.bottom.label"
            }
          ],
