{% assign text_rgb = section.settings['color-body-text'] | color_to_rgb %}

<style>
      #shopify-section-{{ section.id }} {
        --color-overlay-rgb: 0, 0, 0;
        --color-overlay-opacity: 0;
      }
      [data-section-id="{{ section.id }}"]
      {
          {% if section.settings.background_gradient != blank %}
            --color-custom-background: {{ section.settings.background_gradient }};
          {% elsif section.settings.background_color != blank and section.settings.background_color != 'transparent' %}
            --color-custom-background: {{ section.settings.background_color | color_to_rgb }};
          {% endif %}

          {% if section.settings.margin-top %}
              --section-gap-top: {{ section.settings.margin-top }}px;
          {% endif %}

          {% if section.settings.margin-bottom %}
              --section-gap-bottom: {{ section.settings.margin-bottom }}px;
          {% endif %}

          {%- if section.settings.show_mobile_spacing -%}
              --section-gap-top-mobile: {{ section.settings.margin-top-mobile }}px;
          {%- endif -%}

          {%- if section.settings.show_mobile_spacing -%}
              --section-gap-bottom-mobile: {{ section.settings.margin-bottom-mobile }}px;
          {%- endif -%}

          {% if section.settings['color-body-text'] != blank and section.settings['color-body-text'] != 'transparent' and text_rgb != 'rgba(0, 0, 0, 0.0)' %}
            --color-custom-text: {{ section.settings['color-body-text'] }};
          {% endif %}
      }

  {%- for block in section.blocks -%}
      [data-block-id="{{ block.id }}"]
      {
        --font-headline-scale-desk: {{ block.settings.size_heading | divided_by: 100.0 }};

        --font-headline-scale: {{ block.settings.size_heading_mobile | divided_by: 100.0 }};

        {% if block.type == 'countdown_timer' %}
          --font-timer-scale-desk: {{ block.settings.scale_timer | divided_by: 100.0 }};
          --font-timer-scale: {{ block.settings.scale_timer_mobile | divided_by: 100.0 }};
          --font-timer: {% if block.settings.timer_style == 'headline' %}var(--font-headline){% endif %}
        {% endif %}

        {% if block.type == 'icon_with_text' %}
          --icon-height-desktop: {{ block.settings.icon_height_desktop }}px;
          --icon-height: {{ block.settings.icon_height }}px;
          --icon-margin-desktop: {{ block.settings.icon_margin_desktop }}px;
          --icon-margin: {{ block.settings.icon_margin }}px;
          --size-heading-desktop: {{ block.settings.size_heading | divided_by: 100.0 }};
          --size-heading: {{ block.settings.size_heading_mobile | divided_by: 100.0 }};
          --gap: {{ block.settings.gap }}px;
          --margin-top: {{ block.settings.margin_top }}px;
          --margin-bottom: {{ block.settings.margin_bottom }}px;
          --margin-left: {{ block.settings.margin_left }}px;
          --margin-left-desktop: {{ block.settings.margin_left_desktop }}px;
          {% if block.settings.icon_alignment != 'inherit' %}
            --icon-alignment: {{ block.settings.icon_alignment }};
          {% endif %}
          {% if block.settings.icon_alignment_mobile != 'inherit' %}
            --icon-alignment-mobile: {{ block.settings.icon_alignment_mobile }};
          {% endif %}

          {% if block.settings.icon_alignment == "flex-start" %}
            --icon-text-alignment: left;
          {% elsif block.settings.icon_alignment == "flex-end" %}
            --icon-text-alignment: right;
          {% elsif block.settings.icon_alignment == "center" %}
            --icon-text-alignment: center;
          {% endif %}

          {% if block.settings.icon_alignment_mobile == "flex-start" %}
            --icon-text-alignment-mobile: left;
          {% elsif block.settings.icon_alignment_mobile == "flex-end" %}
            --icon-text-alignment-mobile: right;
          {% elsif block.settings.icon_alignment_mobile == "center" %}
            --icon-text-alignment-mobile: center;
          {% endif %}
        {% endif %}

        {% if block.type == 'heading' and block.settings.advanced_heading %}
          {% assign heading_color = section.settings.color-body-text %}
          
          {% if section.settings['color-body-text'] == blank or section.settings['color-body-text'] == 'transparent' or text_rgb == 'rgba(0, 0, 0, 0.0)' %}
            {% assign heading_color = settings.color-headings-text %}
          {% endif %}

          {% if block.settings.heading_richtext_color != blank %}
            {% assign heading_color = block.settings.heading_richtext_color %}
          {% endif %}

          {% if block.settings.heading_richtext_gradient != blank %}
            {% assign heading_color = block.settings.heading_richtext_gradient %}
          {% endif %}

          --color-custom-heading: {{ heading_color }};
        {% endif %}

        {% if block.type == 'text' and block.settings.text_style == 'subtitle' %}
            --font-base: var(--font-headline);
        {% endif %}

        {% if block.type == 'subheading' and block.settings.subheading_advanced_settings %}
          --font-subheading-scale: {{ block.settings.size_text_mobile | divided_by: 100.0 }};
          --font-subheading-scale-desk: {{ block.settings.size_text_desktop | divided_by: 100.0 }};
          --subheading-letter-spacing: {{ block.settings.letter_spacing }}px;
          {% if block.settings.text_uppercase %}
            --subheading-text-transform: uppercase;
          {% endif %}
          {% if block.settings.text_style == 'body' %}
            --subheading-font-family: var(--font-base);
          {% endif %}
        {% endif %}
      }
  {%- endfor -%}
</style>

{% if section.settings['full-width-enabled'] %}
  {% assign width_line = 'hero__wrapper hero__wrapper--full' %}
{% else %}
  {% assign width_line = 'hero__wrapper' %}
{% endif %}

<div
  data-section-id="{{ section.id }}"
  class="rich-text {% if section.settings.compact_size == true %} rich-text--compact{% endif %}"
>
  <div class="{{ width_line }}">
    {% assign classname = '' %}
    {% if section.settings.section_width == 'short' %}
      {% assign classname = 'rich-text--short' %}
    {% endif %}

    {% render 'hero',
      type: 'blocks',
      classname: classname,
      desktop_text_horizontal_position: section.settings.desktop_text_horizontal_position,
      desktop_text_vertical_position: 'center',
      blocks: section.blocks
    %}
  </div>
</div>

