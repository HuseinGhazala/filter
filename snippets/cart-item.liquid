{%liquid
 if request.page_type == 'cart'
  assign tab_index = '0'
 else
   assign tab_index = '-1'
 endif

 assign is_service_product = false
 assign show_qty_remove_controls = true
 assign service_product = settings.cart_additional_service_product
 if settings.cart_show_additional_service and service_product != blank and item.product_id == service_product.id
   assign is_service_product = true
   if settings.cart_additional_service_show_qty_remove == false
     assign show_qty_remove_controls = false
   endif
 endif

 # Detect a service line item whose product became unavailable after it
 # was added to the cart (sold out / archived / draft). The user can
 # still untick the additional-service checkbox to remove the line, so
 # this is purely a visual hint — see _cart.scss `.wt-cart__item--unavailable`.
 assign is_service_unavailable = false
 if is_service_product and item.variant.available == false
   assign is_service_unavailable = true
 endif

 # Service products render the same way on the cart page as in the
 # cart drawer (compact row, no "price under title" block) — locally
 # turn off the cart_page-specific layout for this row only.
 if is_service_product
   assign cart_page = false
 endif
%}

<li id="CartDrawer-Item-{{ item.index | plus: 1 }}" class="cart-item wt-cart__item{% if is_service_unavailable %} wt-cart__item--unavailable{% endif %}">
  <picture class="wt-cart__item__thumb">
    <a href="{{ item.url }}" aria-label="{{ item.title }}" tabindex="{{ tab_index }}" class="wt-cart__item__link">
      {% if item.image %}
        <img
          class="card__img"
          srcset="
            {% if item.image.width >= 375 %}{{ item.image | image_url: width: 375 }} 375w, {% endif %}
            {% if item.image.width >= 750 %}{{ item.image | image_url: width: 750 }} 750w, {% endif %}
            {% if item.image.width >= 1000 %}{{ item.image | image_url: width: 1000 }} 1000w, {% endif %}
            {% if item.image.width >= 1440 %}{{ item.image | image_url: width: 1440 }} 1440w, {% endif %}
            {{ item.image | image_url: width: 1000 }} 1000w
          "
          sizes="(min-width: 1000px) 1000px, 100vw"
          src="{{ item.image | image_url: width: 1000 }}"
          alt="{{ alt }}"
          loading="lazy"
          height="{{ item.image.height }}"
          width="{{ item.image.width }}"
        >
      {% else %}
        {{ 'collection-apparel-1' | placeholder_svg_tag: 'card__img--placeholder' }}
      {% endif %}
      {% if promo %}
        <div class="card__promo">{{ promo }}</div>
      {% endif %}
      {% if save %}
        <a href="#">[]</a>
      {% endif %}
    </a>
  </picture>

  <div class="wt-cart__item__body">
    <div class="wt-cart__item__data">
      {% if show_vendor and item.product.vendor.size > 0 %}
        <span class="card__subtitle">{{ item.product.vendor | escape }}</span>
      {% endif %}
      <h2 class="wt-cart__item__name cart-item__name">
        <p class="wt-cart__item__category">{{ item.product.vendor | escape }}</p>
        <a href="{{ item.product.url }}" tabindex="{{ tab_index }}" class="wt-cart__item__link">{{ item.product.title | escape }}</a>
      </h2>
         {%- if show_qty_remove_controls -%}
        <quantity-counter class="counter-wrapper" data-cart="true">
          <div class="counter">
            <button
              aria-label="{{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}"
              type="button"
              tabindex="{{ tab_index }}"
              class="js-counter-decrease js-counter-button"
            >
              <span class="visually-hidden">
                {{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}
              </span>
              {% render 'icons', id: 'minus' %}
            </button>
            <input
              class="js-counter-quantity"
              data-quantity-variant-id="{{ item.variant.id }}"
              name="updates[]"
              value="{{ item.quantity }}"
              {% # theme-check-disable %}
              data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
              min="{{ item.variant.quantity_rule.min }}"
              {% if item.variant.quantity_rule.max != null %}
                max="{{ item.variant.quantity_rule.max }}"
              {% endif %}
              step="{{ item.variant.quantity_rule.increment }}"
              {% # theme-check-enable %}
              aria-label="Counter quantity"
              id="Drawer-quantity-{{ item.index | plus: 1 }}"
              data-index="{{ item.index | plus: 1 }}"
              tabindex="{{ tab_index }}"
            >
            <button
              aria-label="{{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}"
              type="button"
              class="js-counter-increase js-counter-button"
              tabindex="{{ tab_index }}"
            >
              <span class="visually-hidden">
                {{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}
              </span>
              {% render 'icons', id: 'plus' %}
            </button>
          </div>
        </quantity-counter>
      {%- endif -%}
      {%- if is_service_unavailable -%}
        <p class="wt-cart__item__unavailable">{{ 'products.product.unavailable' | t }}</p>
      {%- endif -%}
      {%- if item.final_price == 0 and cart_page -%}
        <div class="product-option">
          <span class="cart-item__price cart-item__price--free">{{ 'products.product.price.free' | t }}</span>
        </div>
      {%- elsif item.original_price != item.final_price and cart_page -%}
        <div class="cart-item__discounted-prices ">
          <span class="visually-hidden">
            {{ 'products.product.price.regular_price' | t }}
          </span>
          <s class="cart-item__old-price product-option cart-item__price">
            {{- item.original_price | money -}}
          </s>
          <span class="visually-hidden">
            {{ 'products.product.price.sale_price' | t }}
          </span>
          <strong class="cart-item__final-price product-option cart-item__price">
            {{ item.final_price | money }}
          </strong>
        </div>
      {% elsif item.variant.compare_at_price > item.variant.price and cart_page %}
        <div class="cart-item__discounted-prices">
          <span class="visually-hidden">
            {{ 'products.product.price.regular_price' | t }}
          </span>
          <s class="cart-item__old-price price price--end">
            {{ item.variant.compare_at_price | money }}
          </s>
          <span class="visually-hidden">
            {{ 'products.product.price.sale_price' | t }}
          </span>
          <span class="price price--end price--end-sale">
            {{ item.variant.price | money }}
          </span>
        </div>
      {%- elsif cart_page -%}
        <div class="product-option">
          <span class="cart-item__price">{{ item.original_price | money }}</span>
        </div>
      {%- endif -%}
      {%- if show_qty_remove_controls -%}
        <cart-remove-button
          id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
          data-index="{{ item.index | plus: 1 }}"
        >
          <a
            class="wt-cart__item__remove wt-cart__item__remove--title"
            href="#"
            role="button"
            aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}"
            tabindex="{{ tab_index }}"
          >
            {%- render 'icons', id: 'bin' -%}
          </a>
        </cart-remove-button>
      {%- endif -%}
      <div class="options">
        {%- if item.product.has_only_default_variant == false
          or item.properties.size != 0
          or item.selling_plan_allocation != null
        -%}
          {%- if item.product.has_only_default_variant == false -%}
            {%- for option in item.options_with_values -%}
              <div class="product-option">
                <span class="label">{{ option.name }}: </span>
                <span class="value">{{ option.value }}</span>
              </div>
            {%- endfor -%}
          {%- endif -%}
          {%- for property in item.properties -%}
            {%- assign property_first_char = property.first | slice: 0 -%}
            {%- if property.last != blank and property_first_char != '_' -%}
              <div class="product-option">
                <span class="label">{{ property.first }}: </span>
                <span class="value">
                  {%- if property.last contains '/uploads/' -%}
                    <a
                      href="{{ property.last }}"
                      class="link"
                      target="_blank"
                      aria-describedby="a11y-new-window-message"
                    >
                      {{ property.last | split: '/' | last }}
                    </a>
                  {%- else -%}
                    {{ property.last }}
                  {%- endif -%}
                </span>
              </div>
            {%- endif -%}
          {%- endfor -%}
          <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
        {% endif %}
        {% if item.line_level_discount_allocations.size > 0 %}
          <div>
            {% for discount_allocation in item.line_level_discount_allocations %}
              <div class="wt-cart__item-discount">
                {%- render 'icon-discount' -%}
                {{ discount_allocation.discount_application.title }} - {{ discount_allocation.amount | money }}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
    <div class="wt-cart__item__amount cart-page">
      <div class="item__details">
     

        <cart-remove-button
          id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
          data-index="{{ item.index | plus: 1 }}"
        >
          <a
            class="wt-cart__item__remove wt-cart__item__remove--amount"
            href="#"
            aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}"
            role="button"
            tabindex="{{ tab_index }}"
          >
            {%- render 'icons', id: 'bin' -%}
          </a>
        </cart-remove-button>
      
      </div>

      <div class="wt-cart__item__price-wrapper">
        <div class="loading-overlay hidden">
          {% render 'button-loading-indicator', hidden: false %}
        </div>
        {%- if item.final_line_price == 0 -%}
          <span class="price price--end price--end-free">{{ 'products.product.price.free' | t }}</span>
        {%- elsif item.original_line_price != item.final_line_price -%}
          <div class="cart-item__discounted-prices">
            <span class="visually-hidden">
              {{ 'products.product.price.regular_price' | t }}
            </span>
            <s class="cart-item__old-price price price--end">
              {{ item.original_line_price | money }}
            </s>
            <span class="visually-hidden">
              {{ 'products.product.price.sale_price' | t }}
            </span>
            <span class="price price--end">
              {{ item.final_line_price | money }}
            </span>
          </div>
        {% elsif item.selling_plan_allocation.compare_at_price > item.selling_plan_allocation.price %}
          <div class="cart-item__discounted-prices">
            <span class="visually-hidden">
              {{ 'products.product.price.regular_price' | t }}
            </span>
            <s class="cart-item__old-price price price--end">
              {{ item.variant.selling_plan_allocations[0].compare_at_price | times: item.quantity | money }}
            </s>
            <span class="visually-hidden">
              {{ 'products.product.price.sale_price' | t }}
            </span>
            <span class="price price--end price--end-sale">
              {{ item.final_line_price | money }}
            </span>
          </div>
        {% elsif item.variant.compare_at_price > item.variant.price %}
          <div class="cart-item__discounted-prices">
            <span class="visually-hidden">
              {{ 'products.product.price.regular_price' | t }}
            </span>
            <s class="cart-item__old-price price price--end">
              {{ item.variant.compare_at_price | times: item.quantity | money }}
            </s>
            <span class="visually-hidden">
              {{ 'products.product.price.sale_price' | t }}
            </span>
            <span class="price price--end price--end-sale">
              {{ item.final_line_price | money }}
            </span>
          </div>
        {%- else -%}
          <span class="price price--end">
            {{ item.original_line_price | money }}
          </span>
        {%- endif -%}

        {%- if item.variant.available and item.unit_price_measurement -%}
          <div class="unit-price caption">
            <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
            {{ item.unit_price | money }}
            <span aria-hidden="true">/</span>
            <span class="visually-hidden">&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span>
            {%- if item.variant.unit_price_measurement.reference_value != 1 -%}
              {{- item.variant.unit_price_measurement.reference_value -}}
            {%- endif -%}
            {{ item.variant.unit_price_measurement.reference_unit }}
          </div>
        {%- endif -%}
      </div>
      {%- if cart_page -%}
        {% render 'cart-item-error', item: item %}
      {%- endif -%}
    </div>

    {%- unless cart_page -%}
      {% render 'cart-item-error', item: item %}
    {% endunless %}
  </div>
</li>


<style>
.CartDrawer-Item-{{ item.index | plus:1 }}{
  border-bottom: 1px solid gray;
}
.wt-cart__item__category{
 font-size:12px;
}
</style>