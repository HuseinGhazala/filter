{{ 'swiper.css' | asset_url | stylesheet_tag }}
{{ 'module-product-gallery.css' | asset_url | stylesheet_tag }}
{{ 'quick-view-modal.css' | asset_url | stylesheet_tag }}

<modal-dialog
  id="QuickViewModal-{{ product.id }}"
  class="quick-view-modal"
>
  <div
    role="dialog"
    aria-modal="true"
    class="quick-view-modal__content"
    tabindex="-1"
  >
    <div class="quick-view-modal__header">
      <button
        id="ModalClose-{{ product.id }}"
        type="button"
        class="quick-view-modal__close"
        aria-label="{{ 'accessibility.close' | t }}"
      >
        {% render 'icons', id: 'close' %}
      </button>
    </div>
    
    <div class="quick-view-modal__body">
      <div class="quick-view-modal__media">
<div class="quick-view-gallery swiper {% if product.media.size == 1 %}has-single-image{% endif %}">          <ul data-swiper-container class="swiper-wrapper">
            {% if product.selected_or_first_available_variant.featured_media %}
              <li data-swiper-slide class="swiper-slide">
                {{
                  product.selected_or_first_available_variant.featured_media
                  | image_url: width: 600
                  | image_tag:
                    loading: 'lazy',
                    widths: '300, 400, 500, 600',
                    alt: product.selected_or_first_available_variant.featured_media.alt,
                    class: 'quick-view-modal__image'
                }}
              </li>
            {% endif %}
            {% for media in product.media %}
              {% unless media.id == product.selected_or_first_available_variant.featured_media.id %}
                <li data-swiper-slide class="swiper-slide">
                  {% if media.media_type == 'image' %}
                    {{
                      media
                      | image_url: width: 600
                      | image_tag:
                        loading: 'lazy',
                        widths: '300, 400, 500, 600',
                        alt: media.alt,
                        class: 'quick-view-modal__image'
                    }}
                  {%   elsif media.media_type == 'video' %}
                    {{ media | video_tag: class: 'quick-view-modal__video', image_size: '600x', autoplay: true, loop: true, muted: true, controls: false }}
                  {%   elsif media.media_type == 'external_video' %}
                    {{ media | external_video_tag: class: 'quick-view-modal__video' }}
                  {%   elsif media.media_type == 'model' %}
                    {{ media | model_viewer_tag: class: 'quick-view-modal__model' }}
                  {%   endif %}
                </li>
              {% endunless %}
            {% endfor %}
          </ul>
          
          {% if product.media.size > 1 %}
            <div class="swiper-button-next wt-slider__nav-btn wt-slider__nav-next">
              {% render 'icons', id: 'arrow-right' %}
            </div>
            <div class="swiper-button-prev wt-slider__nav-btn wt-slider__nav-prev">
              {% render 'icons', id: 'arrow-left' %}
            </div>
            <div class="swiper-pagination"></div>
          {% endif %}
        </div>
        
        <script data-swiper-configuration type="text/json">
          {
            "grabCursor": true,
            "loop": true,
            "navigation": {
              "nextEl": ".swiper-button-next",
              "prevEl": ".swiper-button-prev"
            },
            "pagination": {
              "el": ".swiper-pagination",
              "clickable": true
            }
          }
        </script>
      </div>
      
      <div class="quick-view-modal__info">
        {% if product.vendor %}
          <p class="quick-view-modal__vendor">{{ product.vendor }}</p>
        {% endif %}
        
        <h2 class="quick-view-modal__title">{{ product.title }}</h2>
        
        {% if product.metafields.reviews.rating.value %}
          <div class="quick-view-modal__rating">
            {% assign percent = product.metafields.reviews.rating.value.rating | times: 20 %}
            {% render 'rating-stars', percent: percent %}
          </div>
        {% endif %}
        
        <div class="quick-view-modal__price-container">
          <span class="quick-view-modal__price" id="Price-{{ product.id }}">
            {{ product.selected_or_first_available_variant.price | money }}
          </span>
          {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
            <span class="quick-view-modal__compare-price" id="ComparePrice-{{ product.id }}">
              <s>{{ product.selected_or_first_available_variant.compare_at_price | money }}</s>
            </span>
          {% endif %}
        </div>
        
        {% if product.description %}
          <div class="quick-view-modal__description rte">
            {{ product.description }}
          </div>
        {% endif %}
        
        {% if product.available %}
          <form method="post" action="/cart/add" id="quick-view-form-{{ product.id }}" class="quick-view-modal__form">
            
            <div class="quick-view-modal__variants">
              {% if product.has_only_default_variant == false %}
                {%- for option in product.options_with_values -%}
                  
                  {%- assign is_color = false -%}
                  {%- assign option_name_lower = option.name | downcase -%}
                  {%- if option_name_lower == 'color' or option_name_lower == 'اللون' -%}
                    {%- assign is_color = true -%}
                  {%- endif -%}

                  {%- if is_color -%}
                    {% assign swatches_config = settings.swatches_config | newline_to_br | split: '<br />' %}
                    <div class="quick-view-modal__colors">
                      <label class="quick-view-modal__colors-label">{{ option.name }}</label>
                      <div class="quick-view-modal__colors-list">
                        {% for value in option.values %}
                          <input
                            type="radio"
                            id="Option-{{ product.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}"
                            name="options[{{ option.name }}]"
                            value="{{ value | escape }}"
                            {% if option.selected_value == value %}checked{% endif %}
                            class="quick-view-modal__variant-input visually-hidden"
                            data-variant-input
                            data-option-index="{{ forloop.parentloop.index0 }}"
                          >
                          <label
                            for="Option-{{ product.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}"
                            class="quick-view-modal__color-swatch"
                            data-option-index="{{ forloop.parentloop.index0 }}"
                            data-option-name="{{ option.name | escape }}"
                            data-color="{{ value | escape }}"
                            style="cursor: pointer; display: inline-block;"
                            aria-label="{{ value }}"
                          >
                            <span
                              class="quick-view-modal__color-swatch-inner"
                              style="{% render 'color-swatch-style', swatches_config: swatches_config, value: value, only_color: true %}"
                            ></span>
                          </label>
                        {% endfor %}
                      </div>
                    </div>

                  {%- else -%}
                    <div class="quick-view-modal__variant">
                      <label class="quick-view-modal__variant-label">
                        {{ option.name }}
                      </label>
                      <div class="quick-view-modal__variant-options">
                        {%- for value in option.values -%}
                          <input
                            type="radio"
                            id="Option-{{ product.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}"
                            name="options[{{ option.name }}]"
                            value="{{ value | escape }}"
                            {% if option.selected_value == value %}checked{% endif %}
                            class="quick-view-modal__variant-input visually-hidden"
                            data-variant-input
                            data-option-index="{{ forloop.parentloop.index0 }}"
                          >
                          <label
                            for="Option-{{ product.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}"
                            class="quick-view-modal__variant-option"
                          >
                            {{ value }}
                          </label>
                        {%- endfor -%}
                      </div>
                    </div>
                  {%- endif -%}

                {%- endfor -%}
              {% endif %}
            </div>

            <input
              type="hidden"
              name="id"
              id="ProductSelect-{{ product.id }}"
              value="{{ product.selected_or_first_available_variant.id }}"
            >
            
        <div class="quick-view-modal__quantity">
  <div class="quantity">
    <select
      class="quantity__select"
      name="quantity"
      id="Quantity-{{ product.id }}"
    >
      {%- for i in (1..10) -%}
        <option value="{{ i }}">{{ i }}</option>
      {%- endfor -%}
    </select>
  </div>
  
  <div class="quick-view-modal__actions">
    <button
      type="submit"
      name="add"
      id="AddToCart-{{ product.id }}"
      class="quick-view-modal__add-to-cart button button--primary"
      {% if product.selected_or_first_available_variant.available == false %}
        disabled
      {% endif %}
    >
      <span>
        {%- if product.selected_or_first_available_variant.available -%}
          {{ 'products.product.add_to_cart' | t }}
        {%- else -%}
          {{ 'products.product.sold_out' | t }}
        {%- endif -%}
      </span>
    </button>
  </div>
</div>
            
            
          </form>
        {% else %}
          <p class="quick-view-modal__sold-out">{{ 'products.product.sold_out' | t }}</p>
        {% endif %}
        
        <a href="{{ product.url }}" class="quick-view-modal__view-full link underlined-link">
          {{ 'products.product.view_full_details' | t }}
        </a>
      </div>
    </div>
  </div>

  <script type="application/json" id="ProductJson-{{ product.id }}">
    {{ product.variants | json }}
  </script>
</modal-dialog>

<script>
  if (!window.quickViewInitialized) {
    window.quickViewInitialized = true;

    document.addEventListener('change', function(e) {
      if (!e.target.matches('[data-variant-input]')) return;
      
      const modal = e.target.closest('modal-dialog');
      if (!modal) return;

      const productId = modal.id.replace('QuickViewModal-', '');
      const jsonContainer = modal.querySelector(`#ProductJson-${productId}`);
      if (!jsonContainer) return;

      const variants = JSON.parse(jsonContainer.textContent);
      const hiddenInput = modal.querySelector(`#ProductSelect-${productId}`);
      const submitButton = modal.querySelector(`#AddToCart-${productId}`);
      const priceSpan = modal.querySelector(`#Price-${productId}`);
      const comparePriceSpan = modal.querySelector(`#ComparePrice-${productId}`);

      const optionInputs = modal.querySelectorAll('[data-variant-input][data-option-index]');
      const availableOptionIndexes = new Set(Array.from(optionInputs, (input) => Number(input.dataset.optionIndex)));

      let selectedOptions = {};
      const checkedInputs = modal.querySelectorAll('[data-variant-input]:checked');
      checkedInputs.forEach(input => {
        const index = parseInt(input.getAttribute('data-option-index'), 10);
        if (!Number.isNaN(index)) selectedOptions[index] = input.value;
      });

      const allOptionsSelected = Object.keys(selectedOptions).length === availableOptionIndexes.size;
      const matchedVariant = allOptionsSelected
        ? variants.find((variant) => variant.options.every((optionValue, idx) => selectedOptions[idx] === optionValue))
        : null;

      if (matchedVariant) {
        // تحديث الـ ID الذي سيتم إرساله للكارت بالـ ID الصحيح والمطابق للمقاس واللون معاً
        hiddenInput.value = matchedVariant.id;

        // تحديث السعر
        if (priceSpan) {
          priceSpan.innerHTML = Shopify.formatMoney ? Shopify.formatMoney(matchedVariant.price) : (matchedVariant.price / 100).toFixed(2);
        }
        
        if (comparePriceSpan) {
          if (matchedVariant.compare_at_price > matchedVariant.price) {
            comparePriceSpan.innerHTML = `<s>${Shopify.formatMoney ? Shopify.formatMoney(matchedVariant.compare_at_price) : (matchedVariant.compare_at_price / 100).toFixed(2)}</s>`;
            comparePriceSpan.style.display = 'inline';
          } else {
            comparePriceSpan.style.display = 'none';
          }
        }

        // تحديث حالة زر الإضافة
        if (matchedVariant.available) {
          submitButton.disabled = false;
          submitButton.querySelector('span').textContent = {{ 'products.product.add_to_cart' | t | json }};
        } else {
          submitButton.disabled = true;
          submitButton.querySelector('span').textContent = {{ 'products.product.sold_out' | t | json }};
        }
      } else {
        // إذا كانت هذه التشكيلة غير متوفرة
        submitButton.disabled = true;
        submitButton.querySelector('span').textContent = "غير متوفر";
      }
    });
  }
</script>