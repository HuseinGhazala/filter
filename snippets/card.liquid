{%- liquid
  assign loading = 'lazy'
  if eager_load
    assign loading = 'eager'
  endif

  if media_aspect_ratio
    if media_aspect_ratio == 'portrait'
      assign aspect_ratio = 'var(--aspect-ratio-portait)'
    elsif card_product.featured_media and media_aspect_ratio == 'adapt'
      assign aspect_ratio = card_product.featured_media.aspect_ratio
    elsif media_aspect_ratio == 'square'
      assign aspect_ratio = 1
    else
      assign aspect_ratio = 'auto'
    endif
  endif

  if settings.enable_product_variations
    assign product_variations_metafield = settings.product_varations_metafield | split: '.' 
    assign product_variations_namespace = product_variations_metafield[0] 
    assign product_variations_key = product_variations_metafield[1] 
    assign product_variations_color_metafield = settings.product_varations_color_metafield | split: '.' 
    assign product_variations_color_namespace = product_variations_color_metafield[0] 
    assign product_variations_color_key = product_variations_color_metafield[1] 
    assign product_variations = product.metafields[product_variations_namespace][product_variations_key].value 
  endif

  if img.alt != blank
    assign card_alt = img.alt | escape
  else
    assign card_alt = title | escape
  endif
-%}

{%- assign title_tag = title_tag | default: 'h3' -%}
{% assign placeholder_title = 'sections.card.placeholder_title' | t %}


<color-swatch
  class="{{ color_swatch_class }}"
  {% if settings.enable_product_variations %}
    data-product-variations
    data-current-variant-handle="{{ card_product.selected_or_first_available_variant.handle | default: card_product.handle }}"
  {% endif %}
  {% if are_filters_active %}
    data-active-filters
  {% endif %}
>
  <div class="card__container" style="--aspect-ratio: {{ aspect_ratio }};">
    <div class="card__picture-container" style="position: relative;">
      <div class="popup-model-btn">
          <div class="product-action-wrapper"   >
 
   <div class="wishlist-btn" data-product-id="{{ product.id }}">
     <svg 
      xmlns="http://www.w3.org/2000/svg" 
      fill="none" 
      viewBox="0 0 24 24" 
      stroke-width="1.5" 
      stroke="currentColor" 
      class="w-6 h-6"
    >
      <path 
        stroke-linecap="round" 
        stroke-linejoin="round" 
        d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" 
      />
    </svg>
   </div>
</div>
        <modal-opener
          class="quick-view-opener no-js-hidden"
          data-modal="#QuickViewModal-{{ product.id }}"
        >
          <button
            type="button"
            class="quick-view-button"
          >
            {% render 'icons', id: 'eye' %}
          </button>
        </modal-opener>
      
      </div>

      <div class="swiper card-product-swiper" style="width: 100%; height: 100%; position: relative; overflow: hidden;">
        <div class="card__loader hidden"></div>
        
        <div class="swiper-wrapper">
          {% if product.media.size > 0 %}
            {% for media in product.media %}
              {% if media.media_type == 'image' %}
                <div class="swiper-slide">
                  <a href="{{ url | default: '#' }}" class="card-main-link" style="display: block; width: 100%; height: 100%;" tabindex="0">
                    <picture class="card__picture" data-uri="{{uri}}" style="display: block; width: 100%; height: 100%;">
                      <img
                        class="card__img"
                        srcset="
                          {% if media.width >= 375 %}{{ media | image_url: width: 375 }} 375w, {% endif %}
                          {% if media.width >= 750 %}{{ media | image_url: width: 750 }} 750w, {% endif %}
                          {% if media.width >= 1000 %}{{ media | image_url: width: 1000 }} 1000w, {% endif %}
                          {{ media | image_url: width: 1000 }} 1000w
                        "
                        sizes="(min-width: 1000px) 620px, 100vw"
                        src="{{ media | image_url: width: 1000 }}"
                        alt="{{ card_alt }}"
                        loading="{{ loading }}"
                        width="{{ media.width }}"
                        height="{{ media.height }}"
                        style="width: 100%; height: 100%; object-fit: cover; pointer-events: none;"
                      >
                    </picture>
                  </a>
                </div>
              {% elsif media.media_type == 'video' and show_video %}
                <div class="swiper-slide">
                  <div class="card__video-container" style="width: 100%; height: 100%;">
                    {{ media | video_tag: image_size: '400x', autoplay: true, loop: true, class: 'card__video', style: 'width:100%; height:100%; object-fit:cover;' }}
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          {% else %}
            <div class="swiper-slide">
              <a href="{{ url | default: '#' }}" class="card-main-link" style="display: block; width: 100%; height: 100%;">
                <picture class="card__picture" style="display: block; width: 100%; height: 100%;">
                  {% if img and img != 'hide' %}
                    <img class="card__img" src="{{ img | image_url: width: 1000 }}" alt="{{ card_alt }}" loading="{{ loading }}" width="{{ img.width }}" height="{{ img.height }}" style="width: 100%; height: 100%; object-fit: cover;">
                  {% else %}
                    {% if placeholder_image_index %}
                      {{ 'product-apparel-' | append: placeholder_image_index | placeholder_svg_tag: 'card__img card__img--placeholder' }}
                    {% else %}
                      {{ 'collection-apparel-1' | append: placeholder_image_index | placeholder_svg_tag: 'card__img card__img--placeholder' }}
                    {% endif %}
                  {% endif %}
                </picture>
              </a>
            </div>
          {% endif %}
        </div>

        {% if product.media.size > 1 %}
          
          <div class="swiper-pagination card-slider-dots"></div>
        {% endif %}

        <div class="card__badges" style="z-index: 10; pointer-events: none;">
          {% assign custom-badge-1-input = settings['custom-badge-1-input'] | downcase %}
          {% assign custom-badge-2-input = settings['custom-badge-2-input'] | downcase %}
          {% assign custom-badge-3-input = settings['custom-badge-3-input'] | downcase %}
          {% assign custom-badge-4-input = settings['custom-badge-4-input'] | downcase %}

          {% if product.available == false %}
            <div class="card__badges--item" data-custom-badge="sold-out">
              {% if settings['badges-uppercase'] == 'uppercase' %}
                {{ 'products.product.sold_out' | t | upcase }}
              {% else %}
                {{ 'products.product.sold_out' | t }}
              {% endif %}
            </div>
          {% endif %}

          {% for tag in product.tags %}
            {% assign downcase_tag = tag | downcase %}
            {% if downcase_tag == custom-badge-1-input %}
              <div class="card__badges--item" data-custom-badge="{{ settings.custom-badge-1-input }}">
                {% if settings['badges-uppercase'] == 'uppercase' %}{{ settings['custom-badge-1-label'] | default: settings['custom-badge-1-input'] | upcase }}{% else %}{{ settings['custom-badge-1-label'] | default: settings['custom-badge-1-input'] }}{% endif %}
              </div>
            {% endif %}
            {% if downcase_tag == custom-badge-2-input %}
              <div class="card__badges--item" data-custom-badge="{{ settings.custom-badge-2-input }}">
                {% if settings['badges-uppercase'] == 'uppercase' %}{{ settings['custom-badge-2-label'] | default: settings['custom-badge-2-input'] | upcase }}{% else %}{{ settings['custom-badge-2-label'] | default: settings['custom-badge-2-input'] }}{% endif %}
              </div>
            {% endif %}
            {% if downcase_tag == custom-badge-3-input %}
              <div class="card__badges--item" data-custom-badge="{{ settings.custom-badge-3-input }}">
                {% if settings['badges-uppercase'] == 'uppercase' %}{{ settings['custom-badge-3-label'] | default: settings['custom-badge-3-input'] | upcase }}{% else %}{{ settings['custom-badge-3-label'] | default: settings['custom-badge-3-input'] }}{% endif %}
              </div>
            {% endif %}
            {% if downcase_tag == custom-badge-4-input %}
              <div class="card__badges--item" data-custom-badge="{{ settings.custom-badge-4-input }}">
                {% if settings['badges-uppercase'] == 'uppercase' %}{{ settings['custom-badge-4-label'] | default: settings['custom-badge-4-input'] | upcase }}{% else %}{{ settings['custom-badge-4-label'] | default: settings['custom-badge-4-input'] }}{% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>

        {% if promo %}
          <div class="card__promo" style="z-index: 10;">{{ promo }}</div>
        {% endif %}
        {% if save %}
          <a href="#">[]</a>
        {% endif %}
      </div>

      {% if enable_quick_add_button and quick_add_mode == 'hover_desktop' %}
        <div class="card__quick-add-container--desktop" style="z-index: 25; position: absolute; bottom: 0; left: 0; width: 100%;">
          {% render 'quick-add-button', card_product: product, product: card_product, product_variations: product_variations %}
        </div>
      {% endif %}
    </div>

    <div class="card{% if text_alignment %} card--{{ text_alignment }}{% endif %}">
      {% if section.settings.show_vendor == true %}
        <p class="card__subtitle">
          {% if enable_vendor_link %}
            <a class="vendor-link" href="/collections/vendors?q={{ product.vendor }}">
          {% endif %}
          {{ subtitle }}
          {% if enable_vendor_link %}
            </a>
          {% endif %}
        </p>
      {% endif %}

      {% if show_vendor_prop == true %}
        <p class="card__subtitle">{{ subtitle }}</p>
      {% endif %}

      <{{ title_tag }} class="card__title">
        <a href="{{ url }}" tabindex="-1" data-omit-tabindex>
          {% if title %}{{ title }}{% else %}{{ default_title | default: placeholder_title }}{% endif %}
        </a>
      </{{ title_tag }}>

      {% if price and collection_list != true %}
        <div class="card__price">
          {% if price_old -%}<span class="card__price__old">{{ price_old }}</span>{%- endif %}
          {% if settings.currency_code_enabled %}{{ price | money_with_currency }}{% else %}{{ price | money }}{% endif %}
        </div>
      {% elsif product and collection_list != true %}
        <div class="card__price">
          {% render 'price', product: product, show_compare_at_price: true, price_class: '' %}
        </div>
      {% endif %}

      {% if rating and reviews %}
        {% render 'rating', reviews: reviews, text_alignment: text_alignment %}
      {% endif %}
    </div>

    {% if settings.enable_product_variations %}
      {% render 'card-product-variation-swatches', 
        product: product, 
        text_alignment: text_alignment,
        product_variations: product_variations,
        product_variations_color_namespace: product_variations_color_namespace,
        product_variations_color_key: product_variations_color_key
      %}
    {% elsif settings.enable_color_swatch %}
      {% render 'card-color-swatches', product: product, text_alignment: text_alignment, are_filters_active: are_filters_active %}
    {% endif %}

    {% if enable_quick_add_button %}
      <div class="card__quick-add-container {% if quick_add_mode == 'hover_desktop' %}card__quick-add-container--hidden{% endif %}" style="z-index: 25; position: relative;">
        {% render 'quick-add-button', card_product: product, product: card_product, product_variations: product_variations %}
      </div>
    {% endif %}
  </div>
  {% render 'quick-view-modal', product: product %}
</color-swatch>


<style>

  
  @media (min-width: 769px) {
    .card__picture-container:hover .card__quick-add-container--desktop { 
      opacity: 1; 
      visibility: visible; 
      transform: translateY(0); 
    }
  }
  



  .card-product-swiper .card-slider-dots {
    bottom: 12px !important;
    background: transparent !important;
    padding: 3px 6px;
    border-radius: 10px;
    width: auto !important;
    left: 50% !important;
    transform: translateX(-50%);
    z-index: 20;
  }
  .card-product-swiper .swiper-pagination .swiper-pagination-bullet { background:var(--color-button-primary-background); }
  .card-product-swiper .swiper-pagination-bullet { background:var(--color-button-primary-background); opacity: 0.7; width: 6px; height: 6px; margin: 0 3px !important; }
  .card-product-swiper .swiper-pagination-bullet-active { background: var(--color-button-primary-background) !important; width: 12px; border-radius: 4px; opacity: 1; }

  .swiper-pagination .swiper-pagination-bullet--svg-animation{
  display: inline-block !important;
  
  }
</style>


