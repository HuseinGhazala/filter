{%- comment -%}
  Enhanced Product JSON-LD with UCP-compliant fields.
  Includes MerchantReturnPolicy, OfferShippingDetails, and itemCondition.
  Requires: product object in scope.
{%- endcomment -%}

{%- liquid
  if product.selected_or_first_available_variant.featured_media
    assign seo_media = product.selected_or_first_available_variant.featured_media
  else
    assign seo_media = product.featured_media
  endif

  assign return_days = settings.ucp_return_days | default: 30
  assign shipping_min_days = settings.ucp_shipping_min_days | default: 3
  assign shipping_max_days = settings.ucp_shipping_max_days | default: 7
  assign processing_days = settings.ucp_processing_days | default: 2
  assign shipping_cost = settings.ucp_shipping_cost | default: 0
  assign free_shipping_threshold = settings.ucp_free_shipping_threshold | default: 0
  assign free_shipping_threshold_cents = free_shipping_threshold | times: 100
-%}

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "url": {{ request.origin | append: product.url | json }},
    {%- if seo_media %}
    "image": [
      {{ seo_media | image_url: width: 1920 | prepend: "https:" | json }}
      {%- for media in product.media limit: 4 -%}
        {%- if media != seo_media and media.media_type == 'image' -%}
          ,{{ media | image_url: width: 1920 | prepend: "https:" | json }}
        {%- endif -%}
      {%- endfor -%}
    ],
    {%- endif %}
    "description": {{ product.description | strip_html | json }},
    {%- if product.selected_or_first_available_variant.sku != blank %}
    "sku": {{ product.selected_or_first_available_variant.sku | json }},
    {%- endif %}
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | json }}
    },
    {%- if settings.ucp_enable_return_policy %}
    "hasReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": {{ localization.country.iso_code | json }},
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": {{ return_days }},
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/FreeReturn"
    },
    {%- endif %}
    "offers": [
      {%- for variant in product.variants -%}
      {
        "@type": "Offer",
        {%- if variant.sku != blank %}
        "sku": {{ variant.sku | json }},
        {%- endif %}
        {%- if variant.barcode.size == 12 %}
        "gtin12": {{ variant.barcode | json }},
        {%- endif %}
        {%- if variant.barcode.size == 13 %}
        "gtin13": {{ variant.barcode | json }},
        {%- endif %}
        {%- if variant.barcode.size == 14 %}
        "gtin14": {{ variant.barcode | json }},
        {%- endif %}
        "availability": "https://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
        "price": {{ variant.price | divided_by: 100.0 }},
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "itemCondition": "https://schema.org/NewCondition",
        "url": {{ request.origin | append: variant.url | json }},
        "seller": {
          "@type": "Organization",
          "name": {{ shop.name | json }}
        }
        {%- if settings.ucp_enable_shipping_details %}
        ,"shippingDetails": {
          "@type": "OfferShippingDetails",
          "deliveryTime": {
            "@type": "ShippingDeliveryTime",
            "handlingTime": {
              "@type": "QuantitativeValue",
              "minValue": 0,
              "maxValue": {{ processing_days }},
              "unitCode": "DAY"
            },
            "transitTime": {
              "@type": "QuantitativeValue",
              "minValue": {{ shipping_min_days }},
              "maxValue": {{ shipping_max_days }},
              "unitCode": "DAY"
            }
          },
          "shippingRate": {
            "@type": "MonetaryAmount",
            "value": {% if free_shipping_threshold_cents > 0 and variant.price >= free_shipping_threshold_cents %}0{% else %}{{ shipping_cost }}{% endif %},
            "currency": {{ cart.currency.iso_code | json }}
          }
        }
        {%- endif %}
      }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
</script>
